<div class="tw:w-full" data-controller="search--everything-combobox">
  <style>
    <%#
      Autocomplete option formatting specific to the EverythingCombobox
      (matches the prior select2 markup). Base + theme styles for the combobox
      come from hw_combobox_style_tag (layout) and combobox.css.
    %>
    .hw-combobox__option .sch_ {
      color: #ccc;
    }

    .hw-combobox__option .sch_c {
      color: #bbb;
      display: inline-block;
    }

    .hw-combobox__option .sclr {
      border-radius: 3px;
      display: inline-block;
      width: 24px;
      height: 24px;
      border: 1px solid rgba(0, 0, 0, 0.2);
      line-height: 0.8em;
      margin: 0 6px -6px;
      font-size: 0.5em;
      text-align: center;
      padding-top: 1em;
    }
  </style>

  <%# The combobox is hidden until the stimulus controller connects, so users %>
  <%# without JS get the plain query field below instead %>
  <div class="tw:hidden" data-search--everything-combobox-target="combobox">
    <%# No preload: options load on type, so every search page isn't loading %>
    <%# autocomplete results on connect %>
    <%= helpers.hw_combobox_tag(
      :query_items_combobox,
      async_src,
      multiselect_chip_src: chips_src,
      free_text: true,
      autocomplete: :list,
      value: selected_value,
      label: translation(".query_items_description"),
      placeholder: translation(".search_descriptions"),
    ) do |combobox| %>
      <% combobox.customize_label class: "tw:sr-only" %>

      <%# The combobox keeps its own comma-joined value here; the stimulus %>
      <%# controller mirrors it into query_items[] fields, so disable submission %>
      <% combobox.customize_hidden_field disabled: true %>
    <% end %>
  </div>

  <%# Non-JS fallback: removed by the stimulus controller once it connects %>
  <%= label_tag :query,
  translation(".search_descriptions"),
  class: "twlabel tw:sr-only",
  data: {"search--everything-combobox-target" => "nonjsfields"} %>

  <%= text_field_tag :query,
  @query,
  placeholder: translation(".search_descriptions"),
  class: "twinput",
  data: {"search--everything-combobox-target" => "nonjsfields"} %>
</div>
