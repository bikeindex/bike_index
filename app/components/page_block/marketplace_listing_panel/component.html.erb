<%= render(UI::Card::Component.new) do %>
  <%# Pill sits above the price on mobile; on desktop it right-aligns across from the price %>
  <div class="tw:flex tw:flex-col tw:items-start tw:lg:flex-row tw:lg:items-center tw:lg:justify-between">
    <h2 class="twtext-color! tw:my-2! tw:text-4xl! tw:font-normal">
      <%= amount_display(@marketplace_listing, currency_name_suffix: true) %>

      <span class="uncap tw:text-xl! tw:opacity-65">
        <%= translation(".price_is_firm_#{@marketplace_listing.price_firm?}") %>
      </span>
    </h2>

    <% if @marketplace_listing.seller_member? %>
      <span class="tw:order-first tw:lg:order-none">
        <%= render(UI::Badge::Component.new(text: translation(".member_listing"), title: translation(".member_listing_tooltip"), color: :purple, size: :md)) %>
      </span>
    <% end %>
  </div>

  <%= render(UI::DefinitionList::Container::Component.new(multi_columns: true)) do %>
    <%= render(UI::DefinitionList::Row::Component.new(label: translation(".condition"))) do %>
      <%= @marketplace_listing.condition_humanized %>

      <em class="less-strong tw:text-sm">
        <%= MarketplaceListing.condition_description_humanized(
          @marketplace_listing.condition,
        ) %>
      </em>
    <% end %>

    <%= render(
      UI::DefinitionList::Row::Component.new(
        label: translation(".location"),
        value: @marketplace_listing.formatted_address_string,
      ),
    ) %>

    <%= render(
      UI::DefinitionList::Row::Component.new(
        label: translation(".first_posted_at"),
        value: @marketplace_listing.published_at,
      ),
    ) %>

    <%= render(
      UI::DefinitionList::Row::Component.new(
        label: translation(".still_for_sale_at"),
        value: still_for_sale_if_show,
      ),
    ) %>

    <%= render(
      UI::DefinitionList::Row::Component.new(
        label: translation(".description"),
        value: @marketplace_listing.description,
        full_width: true,
      ),
    ) %>
  <% end %>
<% end %>
