<div class="kelsey_styles">
  <%# Hero Section %>
  <section class="le-hero-section">
    <div
      class="le-bike-tiles-grid"
      data-controller="landing-pages--bike-tiles"
      data-landing-pages--bike-tiles-target="grid"
      data-landing-pages--bike-tiles-images-value="<%= bike_tile_images.to_json %>"
    ></div>

    <div class="le-hero-content">
      <h1>The #1 platform for bike theft recovery</h1>

      <p class="le-hero-tagline">
        Bike Index is a comprehensive database and management tool that gives
        law enforcement real-time metrics, investigative tools, and a
        community-powered recovery platform, so you can clear more cases and
        protect your community.
      </p>

      <div class="le-hero-buttons">
        <button
          data-open-modal="law-enforcement-demo-modal"
          class="le-btn-primary"
        >
          Schedule a Demo
        </button>
      </div>

      <div class="le-hero-stats">
        <div class="le-stat-item">
          <div class="le-stat-number">2x</div>
          <div class="le-stat-label">Double your recovery rate</div>
        </div>

        <div class="le-stat-item">
          <div class="le-stat-number"><%= recoveries_value_display %></div>
          <div class="le-stat-label">Worth of bikes recovered</div>
        </div>

        <div class="le-stat-item">
          <div class="le-stat-number">
            <%= recoveries_display %>+
          </div>

          <div class="le-stat-label">Stolen bikes recovered</div>
        </div>
      </div>
    </div>
  </section>

  <%# Trusted Municipalities Section %>
  <section class="le-municipalities-section">
    <div class="container">
      <h2>Trusted by law enforcement nationwide</h2>

      <div class="le-partners-carousel-wrapper">
        <div class="le-partners-grid">
          <% 2.times do %>
            <% partner_logos.each do |partner| %>
              <div class="le-partner-logo">
                <%= image_tag partner[:image], alt: partner[:name] %>
                <span><%= partner[:name] %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <%# Features Section %>
  <section class="le-features-section">
    <div class="container">
      <h2>A universal system that outperforms closed local registries</h2>

      <div class="le-features-grid">
        <% FEATURES.each do |feature| %>
          <div class="le-feature-block">
            <div class="le-feature-icon">
              <%= image_tag "kelsey/partners/#{feature[:image]}", alt: feature[:title] %>
            </div>

            <h3><%= feature[:title] %></h3>

            <p><%= feature[:description] %></p>
          </div>
        <% end %>
      </div>

      <%# Tabbed Widget %>
      <div class="le-tabbed-widget" data-controller="landing-pages--tabs">
        <div class="le-tab-buttons">
          <button
            class="le-tab-button active"
            data-tab="database"
            data-landing-pages--tabs-target="button"
            data-action="click->landing-pages--tabs#select"
          >
            All-in-One Database Management for Operational Efficiency
          </button>

          <button
            class="le-tab-button"
            data-tab="defense"
            data-landing-pages--tabs-target="button"
            data-action="click->landing-pages--tabs#select"
          >
            First Line of Defense Against Theft for Your Citizens
          </button>
        </div>

        <div class="le-tab-content">
          <div
            class="le-tab-panel active"
            id="tab-database"
            data-landing-pages--tabs-target="panel"
          >
            <div class="le-tab-panel-content">
              <div class="le-tab-icon">
                <%= image_tag "kelsey/cities.gif", alt: "Database Management" %>
              </div>

              <div class="le-tab-text">
                <p>
                  Your city becomes part of a coordinated, nationally-trusted
                  system so you can clear more cases without increasing
                  workload:
                </p>

                <ul>
                  <li>
                    Our law enforcement dashboard with regional metrics, trend
                    tracking, and exportable reporting to share up the chain of
                    command and manage real-time data
                  </li>

                  <li>
                    Investigate and recover more bikes with QR stickers, serial
                    search, owner credibility badges, impound lot management,
                    LeadsOnline integration, and direct secure messaging with
                    owners.
                  </li>

                  <li>
                    Utilize free bike shop POS integrations, daily stolen bike
                    hot sheets, social alerts, and ambassador networks that
                    expand your reach without increasing staffing
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div
            class="le-tab-panel"
            id="tab-defense"
            data-landing-pages--tabs-target="panel"
          >
            <div class="le-tab-panel-content">
              <div class="le-tab-icon">
                <%= image_tag "kelsey/theft-victims.gif", alt: "First Line of Defense" %>
              </div>

              <div class="le-tab-text">
                <p>
                  Greater security, higher recovery potential, and empowered
                  citizens:
                </p>

                <ul>
                  <li>
                    Be the first line of defense against bike theft and make
                    resale of stolen bikes significantly harder through our
                    public registry, social alerts, and a coordinated recovery
                    network
                  </li>

                  <li>
                    Our partnerships with law enforcement, community
                    organizations, and bike shops increase recovery rates
                    through a free, secure platform
                  </li>

                  <li>
                    Secure digital proof of ownership provides peace of mind for
                    proactive bike owners with privacy-centric controls and
                    communication.
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# Tools Overview Section %>
  <section class="le-tools-section">
    <div class="container">
      <h2>Comprehensive tools for every scenario</h2>

      <div class="le-tools-grid">
        <% TOOLS.each do |tool| %>
          <div class="le-tool-item">
            <%= image_tag "kelsey/lawenforcement/#{tool[:image]}", alt: tool[:title] %>

            <h4><%= tool[:title] %></h4>

            <div class="le-tool-details">
              <p><%= tool[:description] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# Testimonials Section %>
  <section
    class="le-testimonials-section"
    data-controller="landing-pages--testimonials"
  >
    <div class="container">
      <h2>Testimonials</h2>

      <div class="le-testimonials-carousel-wrapper">
        <div class="le-testimonials-grid">
          <% TESTIMONIALS.each_with_index do |testimonial, index| %>
            <div
              class="le-testimonial <%= "active" if index == 0 %>"
              data-landing-pages--testimonials-target="testimonial"
            >
              <div class="le-testimonial-content">
                <div class="le-testimonial-text">
                  <p class="le-testimonial-quote">
                    "<%= testimonial[:quote] %>"
                  </p>

                  <div class="le-testimonial-author">
                    <strong><%= testimonial[:author] %></strong>
                    <span><%= testimonial[:org] %></span>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="le-testimonial-nav">
          <button
            class="le-testimonial-arrow"
            data-action="click->landing-pages--testimonials#prev"
          >
            &lsaquo;
          </button>

          <div class="le-testimonial-dots" data-testimonials-dots></div>

          <button
            class="le-testimonial-arrow"
            data-action="click->landing-pages--testimonials#next"
          >
            &rsaquo;
          </button>
        </div>
      </div>
    </div>
  </section>

  <%# Final CTA Section %>
  <section class="le-cta-section">
    <div class="container">
      <h2>Ready to recover more bikes and clear more crimes?</h2>

      <p class="le-cta-subtitle">
        Join <%= organizations_display %>+ organizations using the world's most
        widely used bike registration network.
      </p>

      <p class="le-nonprofit-message">
        We're a 501(c)(3) non-profit. Our mission is bike theft recovery, not
        profit. Let's talk about what works for your department.
      </p>

      <div class="le-cta-buttons">
        <button
          data-open-modal="law-enforcement-demo-modal"
          class="le-btn-primary"
        >
          Schedule a Demo
        </button>
      </div>
    </div>
  </section>

  <%= render(UI::Modal::Component.new(title: "Contact us for a free trial", id: "law-enforcement-demo-modal")) do |modal| %>
    <% modal.with_body do %>
      <%= form_for @feedback do |f| %>
        <%= render(Form::Group::Component.new(form_builder: f, attribute: :name, label_text: "City", html_options: {required: true})) %>
        <%= render(Form::Group::Component.new(form_builder: f, attribute: :contact_name, label_text: "Name")) %>
        <%= render(Form::Group::Component.new(form_builder: f, attribute: :email, kind: :email_field, html_options: {required: true, value: @current_user&.email})) %>
        <%= render(Form::Group::Component.new(form_builder: f, attribute: :phone_number)) %>

        <div class="tw:hidden">
          <%= render(Form::Group::Component.new(form_builder: f, attribute: :additional, kind: :text_area, label_text: "Additional information")) %>
        </div>

        <%= f.hidden_field :feedback_type, value: "lead_for_city" %>
        <%= f.hidden_field :body, value: "lead" %>

        <div class="tw:pt-2">
          <%= f.submit "Sign up", class: "le-btn-primary tw:w-full tw:cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
