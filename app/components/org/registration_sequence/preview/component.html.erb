<div class="tw:flex tw:flex-col tw:gap-6">
  <% @registration_sequence.registration_sequence_pages.with_attached_image.each do |page| %>
    <div
      class="
        tw:flex tw:flex-col tw:gap-4 tw:rounded tw:border tw:border-gray-200
        tw:p-4 tw:sm:flex-row
      "
    >
      <% if page.image.attached? %>
        <%= image_tag page.image_url, class: "tw:w-full tw:rounded tw:object-cover tw:sm:w-64" %>
      <% end %>

      <div class="tw:flex-1">
        <% if page.title.present? %>
          <h3 class="uncap tw:text-lg tw:font-semibold"><%= page.title %></h3>
        <% end %>

        <% if page.subtitle.present? %>
          <p class="tw:mb-2 tw:text-gray-600"><%= page.subtitle %></p>
        <% end %>

        <div class="tw:prose tw:max-w-none">
          <%= page.body&.html_safe %>
        </div>
      </div>
    </div>
  <% end %>
</div>
