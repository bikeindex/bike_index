<div
  data-bullet-editors-target="item"
  class="tw:mb-2 tw:flex tw:items-start tw:gap-2"
>
  <%= render UI::DragHandle::Component.new(controller: "bullet-editors", html_class: "tw:pt-2") %>

  <div class="tw:flex-1">
    <%= render Form::TextEditor::Component.new(form_builder: bullet_builder, attribute: :content, size: :single_line, value: @value) %>
  </div>

  <%= render UI::Button::Component.new(text: "Remove", color: :link, html_class: "tw:pt-2 tw:text-xs", data: {action: "bullet-editors#remove"}) %>
</div>
