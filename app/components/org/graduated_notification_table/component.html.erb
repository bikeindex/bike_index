<table class="table table-striped table-bordered table-sm without-exterior-border">
  <thead class="small-header hidden-md-down">
    <th><%= sortable "created_at", render_sortable: @render_sortable %></th>
    <th class="small"><%= sortable "processed_at", "Sent", render_sortable: @render_sortable %></th>
    <% if @separate_secondary_notifications %>
      <th>Primary?</th>
    <% end %>
    <th><%= @separate_secondary_notifications ? "Bike" : "Bike(s)" %></th>
    <% unless @skip_status %>
      <th>Status</th>
    <% end %>
    <% unless @skip_email %>
      <td><%= sortable "email", render_sortable: @render_sortable %></td>
    <% end %>
    <% if @render_remaining_at %>
      <td><%= sortable "marked_remaining_at", "Marked Not Graduated", render_sortable: @render_sortable %></td>
    <% end %>
  </thead>

  <tbody>
    <% @graduated_notifications.each do |graduated_notification| %>
      <tr>
        <td>
          <% if helpers.display_dev_info? %>
            <small class="only-dev-visible"><%= graduated_notification.id %></small>
          <% end %>
          <a class="localizeTime preciseTime" href="<%= organization_graduated_notification_path(notification_link(graduated_notification).to_param, organization_id: graduated_notification.organization_id) %>">
            <%= l(graduated_notification.created_at, format: :convert_time) %>
          </a>
        </td>
        <td class="small">
          <% if graduated_notification.processed_at.present? %>
            <span class="localizeTime"><%= l(graduated_notification.processed_at, format: :convert_time) %></span>
          <% else %>
            <small class="less-strong">
              @
              <span class="localizeTime"><%= l(graduated_notification.pending_period_ends_at, format: :convert_time) %></span>
            </small>
          <% end %>
        </td>
        <% if @separate_secondary_notifications %>
          <td><%= helpers.check_mark if graduated_notification.primary_notification? %></td>
        <% end %>
        <td>
          <% if graduated_notification.bike.present? %>
            <%= link_to helpers.organized_bike_text(graduated_notification.bike), bike_path(graduated_notification.bike, organization_id: org_param_for(graduated_notification)) %>
          <% end %>
          <% unless @separate_secondary_notifications %>
            <% graduated_notification.associated_notifications.each do |associated_notification| %>
              <small class="d-block" style="padding-left: 0.5rem; line-height: 1.5">
                <%= link_to helpers.organized_bike_text(associated_notification.bike), bike_path(associated_notification.bike, organization_id: org_param_for(associated_notification)) %>
              </small>
            <% end %>
          <% end %>
        </td>
        <% unless @skip_status %>
          <td><%= helpers.status_display(graduated_notification.status_humanized&.titleize) %></td>
        <% end %>
        <% unless @skip_email %>
          <td>
            <%= graduated_notification.email %>
            <% unless @skip_email_search %>
              <small><%= link_to "🔎", url_for(sortable_search_params.merge(search_email: graduated_notification.email)) %></small>
            <% end %>
          </td>
        <% end %>
        <% if @render_remaining_at %>
          <td>
            <% if graduated_notification.marked_remaining_at.present? %>
              <span class="localizeTime"><%= l(graduated_notification.marked_remaining_at, format: :convert_time) %></span>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
