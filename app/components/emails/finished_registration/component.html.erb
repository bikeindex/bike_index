<table
  class="finished-registration-shell"
  width="100%"
  cellpadding="0"
  cellspacing="0"
  border="0"
>
  <tbody>
    <tr>
      <td>
        <%# MailSnippets are english-only for now %>
        <% if organization_snippet_body('welcome').present? %>
          <%= organization_snippet_body('welcome').html_safe %>
        <% end %>

        <div class="finished-registration-card finished-registration-intro">
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            border="0"
          >
            <tbody>
              <tr>
                <td class="intro-art-cell">
                  <%= image_tag template_asset_url("bike-index-registered-single-loop.gif"),
                    alt: translation("registered_animation"),
                    class: "intro-art" %>
                </td>

                <td class="intro-copy-cell">
                  <h1 class="<%= 'uncap' unless bike.status_stolen? || bike.status_impounded? || claim_message? %>">
                    <%= intro_heading %>
                  </h1>

                  <% if intro_body.present? %>
                    <p class="intro-body"><%= intro_body %></p>
                  <% end %>
                </td>
              </tr>
            </tbody>
          </table>

          <% if show_organization_stolen_message? %>
            <%= render partial: "/bikes/organization_stolen_message", locals: {stolen_record: bike.current_stolen_record} %>
          <% end %>

          <% if claim_message? %>
            <%= render partial: "/shared/claim_message", locals: {bike:, skip_to_see: true} %>
          <% else %>
            <p><%= detail_message %></p>
            <% unless claimed? %>
              <p class="finished-registration-kicker">
                <strong>
                  <%= translation("youre_almost_done_registering") %>
                </strong>
              </p>
            <% end %>
          <% end %>
        </div>

        <% if show_after_welcome_snippet? %>
          <%= organization_snippet_body("after_welcome").html_safe %>
        <% end %>

        <div class="finished-registration-card finished-registration-bike-box">
          <h3><%= translation("bike_details") %></h3>
          <%= render(Emails::Partials::BikeBox::Component.new(bike:, ownership: @ownership, bike_url_path: bike_url_with_token)) %>

          <% if bike.status_stolen_or_impounded? %>
            <p class="finished-registration-status-note">
              <% if bike.status_impounded? %>
                <%= translation("hopefully_you_find_the_owner_prefix") %>
                <%= link_to translation("give_us_a_heads_up"), edit_bike_url(bike) %>
                <%= translation("hopefully_you_find_the_owner_suffix") %>
              <% else %>
                <%= translation("hopefully_you_find_the_bike", bike_type: bike.type) %>
                <strong>
                  <%= link_to(translation("mark_your_bike_recovered"), recovery_url, "data-pm-no-track" => true) %>
                  <%= translation("when_you_do") %>
                </strong>
              <% end %>
            </p>
          <% end %>

          <% if donation_message? %>
            <div class="donate-message">
              <h5>
                <%= translation("please_consider_prefix") %>
                <%= link_to translation("donating"), why_donate_url %>
                <%= translation("please_consider_suffix") %>
              </h5>

              <p>
                <%= translation("a_donation_will_prioritize_prefix") %>
                <%= link_to translation("prioritize_your_listing"), news_url('get-your-donations-in-this-summer-to-help-bike-index-master-bike-seaso') %>
                <%= translation("a_donation_will_prioritize_suffix") %>
              </p>
            </div>
          <% end %>

          <% unless claimed? %>
            <div class="finished-registration-cta">
              <%= link_to claim_cta_text, bike_url_with_token, "data-pm-no-track" => true, class: "binx-button" %>

              <p>
                <%= translation("sign_up_on_bikeindexorg_to_claim_your_bik", bike_type: bike.type) %>
              </p>
            </div>
          <% end %>
        </div>

        <% if show_security_snippet? %>
          <%= organization_snippet_body("security").html_safe %>
        <% elsif show_default_security_section? %>
          <div class="finished-registration-card finished-registration-security">
            <h2>
              <%= translation("protect_your_bike_by_following_these_lock") %>
            </h2>

            <table
              width="100%"
              cellpadding="0"
              cellspacing="0"
              border="0"
              class="finished-registration-locking-row"
            >
              <tbody>
                <tr>
                  <td class="locking-copy">
                    <h3>
                      <%= translation("use_a_ulock") %> <%= translation("cable_locks_should_never_be_used") %>
                    </h3>
                  </td>

                  <td class="locking-art">
                    <%= image_tag template_asset_url("assets-howtolock-fighter.png"),
                      alt: translation("ulock_illustration"),
                      class: "locking-inline-art" %>
                  </td>
                </tr>
              </tbody>
            </table>

            <table
              width="100%"
              cellpadding="0"
              cellspacing="0"
              border="0"
              class="finished-registration-locking-row"
            >
              <tbody>
                <tr>
                  <td class="locking-copy locking-copy-wide">
                    <p>
                      <%= translation("secure_both_wheels_either_with_two_ulocks") %> <%= translation("before_locking_check") %>
                    </p>
                  </td>
                </tr>

                <tr>
                  <td class="locking-main-art">
                    <%= image_tag template_asset_url("assets-howtolock-main.png"),
                      alt: translation("correctly_locking_a_bike"),
                      title: translation("pink_power_ulocks_tm"),
                      class: "locking-main-image" %>
                  </td>
                </tr>
              </tbody>
            </table>

            <table
              width="100%"
              cellpadding="0"
              cellspacing="0"
              border="0"
              class="finished-registration-pro-tip"
            >
              <tbody>
                <tr>
                  <td class="pro-tip-copy">
                    <p>
                      <%= translation("indoor_storage_tip") %>
                      <%= translation("read_more_about_prefix") %>
                      <%= link_to translation("protecting_your_bike_here"), protect_your_bike_url %>.
                    </p>
                  </td>

                  <td class="pro-tip-art">
                    <%= image_tag template_asset_url("assets-howtolock-protip.png"),
                      alt: translation("pro_tip_illustration"),
                      class: "pro-tip-image" %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        <% end %>

        <% if show_whats_next_section? %>
          <div class="finished-registration-card finished-registration-next-steps">
            <h2><%= translation("whats_next") %></h2>

            <table
              width="100%"
              cellpadding="0"
              cellspacing="0"
              border="0"
            >
              <tbody>
                <tr>
                  <td class="next-step">
                    <%= image_tag template_asset_url("theft-victims.gif"),
                      alt: translation("theft_victims_illustration"),
                      class: "next-step-art" %>

                    <h3><%= translation("what_if_my_bike_gets_stolen") %></h3>
                    <p><%= translation("stolen_guidance") %></p>
                  </td>

                  <td class="next-step">
                    <%= image_tag template_asset_url("marketplace.gif"),
                      alt: translation("marketplace_illustration"),
                      class: "next-step-art" %>

                    <h3>
                      <%= translation("keep_your_registration_updated") %>
                    </h3>

                    <p><%= translation("updated_registration_guidance") %></p>
                  </td>
                </tr>
              </tbody>
            </table>

            <div class="finished-registration-cta subtle">
              <%= link_to translation("view_your_bike"), bike_url_with_token, "data-pm-no-track" => true, class: "binx-button" %>
            </div>
          </div>
        <% end %>

        <% if show_template_promo_section? %>
          <div class="finished-registration-card finished-registration-promo">
            <div class="promo-callout">
              <p>
                <strong><%= translation("spread_the_word_title") %></strong>
                <%= translation("spread_the_word_body") %>
              </p>

              <% if claimed? %>
                <%= link_to translation("view_your_bike"), bike_url_with_token, "data-pm-no-track" => true, class: "binx-button" %>
              <% end %>
            </div>

            <table
              width="100%"
              cellpadding="0"
              cellspacing="0"
              border="0"
              class="finished-registration-comics"
            >
              <tbody>
                <tr>
                  <td class="comic-cell">
                    <%= image_tag template_asset_url("comic-assets_bike-love-1.png"),
                      alt: translation("bike_love_one"),
                      class: "comic-image" %>
                  </td>

                  <td class="comic-cell">
                    <%= image_tag template_asset_url("comic-assets_bike-love-2.png"),
                      alt: translation("bike_love_two"),
                      class: "comic-image" %>
                  </td>

                  <td class="comic-cell">
                    <%= image_tag template_asset_url("comic-assets_bike-love-3.png"),
                      alt: translation("bike_love_three"),
                      class: "comic-image" %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        <% end %>
      </td>
    </tr>
  </tbody>
</table>

<% if render_tempo_snippet? %>
  <%= tempo_snippet.body.html_safe %>
<% end %>
