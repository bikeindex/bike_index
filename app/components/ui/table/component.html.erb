<div class="tw:mb-4" data-controller="table-overflow">
  <table class="<%= table_classes %>">
    <thead class="tw:text-sm tw:text-gray-700 tw:bg-gray-50 dark:tw:bg-gray-700 dark:tw:text-gray-400">
      <tr>
        <% @columns.each do |col| %>
          <th class="tw:px-4 tw:py-3 <%= col.classes %>">
            <% if col.sortable.present? %>
              <%= render_sortable(col.sortable) %>
            <% else %>
              <%= col.label %>
            <% end %>
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody class="tw:divide-y tw:divide-gray-200 dark:tw:divide-gray-700">
      <% @records.each do |record| %>
        <% cache_if(@cache_key, [@cache_key, record]) do %>
          <tr class="tw:bg-white dark:tw:bg-gray-800">
            <% @columns.each do |col| %>
              <td class="tw:px-1 tw:py-1 <%= col.classes %>">
                <%= capture { instance_exec(record, &col.block) } %>
              </td>
            <% end %>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
