<%#
  The gem's base stylesheet isn't yet wired into an app layout; load it here so the preview
  renders styled. The compact overrides ship in tailwind.css (loaded by the layout).
%>
<%= stylesheet_link_tag "lexxy" %>

<%# data-controller="lexxy" lazily loads the editor bundle, which upgrades the <lexxy-editor> %>
<div data-controller="lexxy">
  <%= form_with(model: OrganizationFeature.new(description: "<p>A rich-text description</p>"), url: "#", builder: BikeIndexFormBuilder) do |f| %>
    <%= render(Form::TextEditor::Component.new(form_builder: f, attribute: :description, size: local_assigns.fetch(:size, :normal))) %>
  <% end %>
</div>
