<%= form_with(url: "#", builder: BikeIndexFormBuilder) do |f| %>
  <%= render(Form::Group::Component.new(
    form_builder: f,
    attribute: :status,
    kind: :radio_button_group,
    entries: [
      {value: "", label: "All"},
      {value: "active", label: "Active"},
      {value: "inactive", label: "Inactive"}
    ],
    selected: "active"
  )) %>
<% end %>
