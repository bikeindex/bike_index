<% nav_header_list_items = capture do %>
  <% if current_organization.present? %>
    <li class="nav-item">
      <%= link_to "#{current_organization.short_name} view", organization_graduated_notifications_path({organization_id: current_organization.to_param}.merge(sortable_search_params)), class: "nav-link strong" %>
    </li>
  <% end %>

  <li class="nav-item dropdown">
    <a
      class="nav-link dropdown-toggle <%= @search_status == 'all' ? '' : 'active' %>"
      href="#"
      role="button"
      data-toggle="dropdown"
      aria-haspopup="true"
      aria-expanded="false"
    >
      <%= @search_status.humanize %> notifications
    </a>

    <div class="dropdown-menu">
      <% (["all"] + GraduatedNotification.statuses).each do |kind| %>
        <% kind_active = @search_status == kind %>
        <% kind_display = "#{GraduatedNotification.status_humanized(kind)} notifications" %>

        <%= link_to kind_display, url_for(sortable_search_params.merge(search_status: (kind_active ? nil : kind))), class: "dropdown-item #{kind_active ? 'active' : ''}" %>

        <% if kind == "all" %>
          <div class="dropdown-divider"></div>
        <% end %>
      <% end %>
    </div>
  </li>
<% end %>

<% rendered_chart = capture do %>
  <% if @render_chart %>
    <% time_range_column = @search_status == "marked_remaining" ? "marked_remaining_at" : "created_at" %>
    <% data = UI::Chart::Component.time_range_counts(collection: matching_graduated_notifications, time_range: @time_range, column: time_range_column) %>
    <%= render(UI::Chart::Component.new(series: [{name: "Graduated Notifications", data:}], time_range: @time_range, stacked: true)) %>
  <% end %>
<% end %>

<%= render(Admin::IndexSkeleton::Component.new(
  collection: @graduated_notifications,
  index_title: "Graduated notifications",
  nav_header_list_items:,
  rendered_chart:
)) %>
