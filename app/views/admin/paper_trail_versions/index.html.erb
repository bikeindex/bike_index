<% if params[:search_item_type].present? || params[:search_item_id].present? %>
  <p class="pagination-number">
    Versions for
    <% if params[:search_item_type].present? %>
      <strong><%= params[:search_item_type] %></strong>
    <% end %>
    <% if params[:search_item_id].present? %>
      #<strong><%= params[:search_item_id] %></strong>
    <% end %>
    <%= link_to "view all", admin_paper_trail_versions_path(sortable_search_params.merge(search_item_type: nil, search_item_id: nil)), class: "gray-link tw:text-sm" %>
  </p>
<% end %>

<%= render(Admin::IndexSkeleton::Component.new(
  chart_collection: @render_chart && matching_versions
)) %>
