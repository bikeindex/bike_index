<%# locals: (collection:, render_sortable: false) %>

<%= render(UI::Table::Component.new(records: collection)) do |table| %>
  <% table.column(sortable: render_sortable ? "created_at" : nil, label: "Created") do |strava_request| %>
    <span class="localizeTime">
      <%= l strava_request.created_at, format: :convert_time %>
    </span>

    <% if helpers.display_dev_info? %>
      <span class="less-strong-right d-none d-md-block only-dev-visible">
        <%= strava_request.id %>
      </span>
    <% end %>
  <% end %>

  <% table.column(sortable: render_sortable ? "updated_at" : nil, label: "Updated", classes: "tw:text-xs") do |strava_request| %>
    <small class="localizeTime">
      <%= l strava_request.updated_at, format: :convert_time %>
    </small>
  <% end %>

  <% if display_dev_info? %>
    <% table.column(sortable: render_sortable ? "priority" : nil, label: "Priority", classes: "only-dev-visible tw:text-xs") do |strava_request| %>
      <small title="<%= number_with_delimiter(strava_request.priority) %>">
        <%= (strava_request.priority / 100_000_000.0).round(1) %>
      </small>
    <% end %>
  <% end %>

  <% table.column(sortable: render_sortable ? "request_type" : nil, label: "Type") do |strava_request| %>
    <span class="tw:inline-flex tw:items-center tw:gap-1 tw:whitespace-nowrap">
      <small><%= strava_request.request_type&.humanize %></small>

      <% if strava_request.proxy_request? %>
        <%= render UI::Badge::Component.new(
          text: "p",
          title: "Proxy request",
          color: :gray,
          size: :sm) %>
      <% end %>
    </span>
  <% end %>

  <% table.column(sortable: render_sortable ? "response_status" : nil, label: "Status") do |strava_request| %>
    <% status_text = if strava_request.response_status.start_with?("binx_response")
      strava_request.response_status == "binx_response" ? "binx" : "binx limited"
    else
      strava_request.response_status.humanize
    end %>

    <%= render UI::Badge::Component.new(
      text: status_text,
      title: strava_request.response_status.humanize,
      color: Admin::StravaRequestsChart::Component::RESPONSE_STATUS_BADGE_COLORS[strava_request.response_status.to_sym],
      size: :sm
    ) %>
  <% end %>

  <% table.column(label: "Params") do |strava_request| %>
    <small>
      <%= strava_request.parameters&.to_json if strava_request.parameters.present? %>
    </small>
  <% end %>

  <% table.column(label: "Rate limit") do |strava_request| %>
    <%= render Admin::StravaRateLimit::Component.new(rate_limit_json: strava_request.rate_limit) %>
  <% end %>

  <% table.column(sortable: render_sortable ? "requested_at" : nil, label: "Requested") do |strava_request| %>
    <% if strava_request.requested_at.present? %>
      <small class="localizeTime">
        <%= l strava_request.requested_at, format: :convert_time %>
      </small>
    <% end %>
  <% end %>

  <% table.column(label: "User") do |strava_request| %>
    <%= render Admin::UserCell::Component.new(user: strava_request.user, user_id: strava_request.user_id, render_search: render_sortable, user_link_path: admin_strava_integration_path(strava_request.strava_integration_id), search_url: url_for(sortable_search_params.merge(search_strava_integration_id: strava_request.strava_integration_id))) %>
  <% end %>
<% end %>
