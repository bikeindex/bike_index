<%# locals: (bike_stickers:, render_sortable: false, skip_updates: false) %>

<% bike_code_batch_organizations = BikeStickerBatch.all.map { |b| [b.id.to_s, b.organization&.short_name] }.to_h %>

<%= render(UI::Table::Component.new(records: bike_stickers, render_sortable:)) do |table| %>
  <% table.column(sortable: "created_at", lower_right: ->(r) { content_tag(:span, r.id, class: "only-dev-visible") }) do |bike_sticker| %>
    <% if bike_sticker.organization.present? %>
      <% bike_sticker_url = edit_organization_sticker_path(organization_id: bike_sticker.organization_id, id: bike_sticker.code) %>
    <% else %>
      <% bike_sticker_url = "/bikes/scanned/#{bike_sticker.code}" %>
    <% end %>

    <%= link_to bike_sticker_url do %>
      <%= render UI::Time::Component.new(time: bike_sticker.created_at) %>
    <% end %>
  <% end %>

  <% table.column(sortable: "updated_at", classes: "tw:text-xs") do |bike_sticker| %>
    <small>
      <%= link_to admin_bike_sticker_updates_path(search_bike_sticker_id: bike_sticker.id) do %>
        <%= render UI::Time::Component.new(time: bike_sticker.updated_at) %>
      <% end %>
    </small>
  <% end %>

  <% unless skip_updates %>
    <% table.column(label: "Updates", header_classes: "tw:font-normal") do |bike_sticker| %>
      <%= link_to number_display(bike_sticker.bike_sticker_updates.count), admin_bike_sticker_updates_path(search_bike_sticker_id: bike_sticker.id) %>
    <% end %>
  <% end %>

  <% table.column(sortable: "organization_id") do |bike_sticker| %>
    <%= render Admin::OrganizationCell::Component.new(organization: bike_sticker.organization, render_search: true) %>
  <% end %>

  <% table.column(sortable: "bike_sticker_batch_id", label: "Batch") do |bike_sticker| %>
    <% if bike_sticker.bike_sticker_batch.present? %>
      <%= link_to bike_sticker.bike_sticker_batch_id, admin_bike_stickers_path(sortable_search_params.merge(search_bike_sticker_batch_id: bike_sticker.bike_sticker_batch_id)) %>
      <small class="less-strong">
        <%= bike_code_batch_organizations[bike_sticker.bike_sticker_batch_id.to_s] %>
      </small>
    <% end %>
  <% end %>

  <% table.column(sortable: "claimed_at") do |bike_sticker| %>
    <% if bike_sticker.claimed? && bike_sticker.claimed_at.present? %>
      <%= render UI::Time::Component.new(time: bike_sticker.claimed_at) %>
    <% end %>
  <% end %>

  <% table.column(label: "Bike", header_classes: "tw:font-normal") do |bike_sticker| %>
    <% if bike_sticker.claimed? %>
      <%= helpers.organized_bike_text(bike_sticker.bike) %>
    <% elsif bike_sticker.bike_id.present? %>
      <%= link_to bike_sticker.bike_id, admin_bike_path(bike_sticker.bike_id), class: "small" %>
      <small class="text-danger">Deleted?</small>
    <% end %>
  <% end %>

  <% table.column(sortable: "code_integer", label: "Code #") do |bike_sticker| %>
    <strong>
      <%= link_to bike_sticker.pretty_code, "/bikes/scanned/#{bike_sticker.code}?organization_id=#{bike_sticker.organization.to_param}" %>
    </strong>

    <% unless bike_sticker.sticker? %>
      <em class="small text-warning"><%= bike_sticker.kind %></em>
    <% end %>
  <% end %>
<% end %>
