<%# locals: (collection:, render_sortable: false, skip_strava_integration: false) %>

<%= render(UI::Table::Component.new(records: collection)) do |table| %>
  <% table.column(sortable: render_sortable ? "created_at" : nil, label: "Created") do |strava_gear| %>
    <%= render UI::Time::Component.new(time: strava_gear.created_at) %>

    <% if helpers.display_dev_info? %>
      <span class="less-strong-right d-none d-md-block only-dev-visible">
        <%= strava_gear.id %>
      </span>
    <% end %>
  <% end %>

  <% table.column(sortable: render_sortable ? "updated_at" : nil, label: "Updated", classes: "tw:text-xs") do |strava_gear| %>
    <small>
      <%= render UI::Time::Component.new(time: strava_gear.updated_at) %>
    </small>
  <% end %>

  <% table.column(label: "Name") do |strava_gear| %>
    <%= strava_gear.strava_gear_display_name %>
  <% end %>

  <% table.column(sortable: render_sortable ? "gear_type" : nil, label: "Type") do |strava_gear| %>
    <%= strava_gear.gear_type %>
  <% end %>

  <% table.column(label: "Gear ID") do |strava_gear| %>
    <code><%= strava_gear.strava_id %></code>
  <% end %>

  <% table.column(sortable: render_sortable ? "total_distance_kilometers" : nil, label: "Distance (mi)") do |strava_gear| %>
    <%= number_display(strava_gear.total_distance_miles) %>
  <% end %>

  <% table.column(label: "Enriched") do |strava_gear| %>
    <% if strava_gear.enriched? %>
      <%= render UI::Badge::Component.new(text: "E", title: "Enriched", color: :cyan, size: :sm) %>
    <% end %>
  <% end %>

  <% table.column(label: "Linked Bike") do |strava_gear| %>
    <% if strava_gear.item.present? %>
      <%= link_to strava_gear.item.title_string.truncate(30), bike_path(strava_gear.item), class: "small" %>
    <% end %>
  <% end %>

  <% table.column(label: "Activities") do |strava_gear| %>
    <%= number_display(strava_gear.calculated_strava_activities.count) %>
  <% end %>

  <% unless skip_strava_integration %>
    <% table.column(label: "User") do |strava_gear| %>
      <%= render Admin::UserCell::Component.new(user: strava_gear.strava_integration.user, user_id: strava_gear.strava_integration.user_id, render_search: render_sortable, user_link_path: admin_strava_integration_path(strava_gear.strava_integration_id), search_url: url_for(sortable_search_params.merge(search_strava_integration_id: strava_gear.strava_integration_id))) %>
    <% end %>
  <% end %>
<% end %>
