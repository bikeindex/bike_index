<%# locals: (collection:, render_sortable: false) %>

<div class="full-screen-table">
  <table class="table table-striped table-bordered table-sm">
    <thead class="sortable">
      <th><%= sortable "created_at", render_sortable: render_sortable %></th>

      <th class="small">
        <%= sortable "updated_at", render_sortable: render_sortable %>
      </th>

      <th><%= sortable "bike_id", render_sortable: render_sortable %></th>
      <th>message</th>
      <th>sent</th>
    </thead>

    <tbody>
      <% collection.each do |stolen_notification| %>
        <tr>
          <td>
            <a
              class="localizeTime"
              href="<%= admin_stolen_notification_url(stolen_notification) %>"
            >
              <%= l stolen_notification.created_at, format: :convert_time %>
            </a>
          </td>

          <td>
            <small class="localizeTime">
              <%= l stolen_notification.created_at, format: :convert_time %>
            </small>
          </td>

          <td>
            <% if stolen_notification.bike %>
              <div class="less-strong-hold">
                <span class="less-strong-right">
                  <%= link_to stolen_notification.bike_id, edit_admin_stolen_bike_url(stolen_notification.bike) %>
                </span>

                <%= stolen_notification.bike.title_string %>
              </div>
            <% else %>
              Bike deleted!
            <% end %>
          </td>

          <td><%= stolen_notification.message.truncate(120) %></td>

          <td class="table-cell-check">
            <% if stolen_notification.send_dates_parsed.count == 0 %>
              <span class="text-danger">no</span>
            <% elsif stolen_notification.send_dates_parsed.count == 1 %>
              <%= check_mark %>
            <% else %>
              <%= stolen_notification.send_dates_parsed.count %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
