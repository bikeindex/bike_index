<%# locals: (collection:, render_sortable: true) %>

<% org_ids = OrganizationModelAudit.distinct.pluck(:organization_id) %>
<% org_names_hash = Organization.where(id: org_ids).pluck(:id, :short_name).to_h %>

<% unless display_dev_info? %>
  <style>.only-dev-visible {display: none !important;}</style>
<% end %>

<div class="full-screen-table">
  <table class="table table-striped table-bordered table-sm without-exterior-border">
    <thead class="small-header">
      <th class="small">
        <%= sortable "created_at", render_sortable: render_sortable %>
      </th>

      <th class="small">
        <%= sortable "updated_at", render_sortable: render_sortable %>
      </th>

      <th>
        <%= sortable "mnfg_name", "Manufacturer", render_sortable: render_sortable %>
      </th>

      <th><small>Mnfg other</small></th>

      <th>
        <%= sortable "frame_model", "Model", render_sortable: render_sortable %>
      </th>

      <th>
        <%= sortable "bikes_count", "Vehicles #", render_sortable: render_sortable %>
      </th>

      <td>Org vehicles</td>
      <td>Attestations</td>
    </thead>

    <tbody>
      <% collection.each do |model_audit| %>
        <% cache(model_audit) do %>
          <tr>
            <td>
              <span class="localizeTime">
                <%= l model_audit.created_at, format: :convert_time %>
              </span>

              <code class="small only-dev-visible"><%= model_audit.id %></code>
            </td>

            <td class="small">
              <span class="localizeTime">
                <%= l model_audit.updated_at, format: :convert_time %>
              </span>
            </td>

            <td>
              <%= model_audit.mnfg_name %>

              <small>
                <%= link_to "🔎", url_for(sortable_search_params.merge(search_mnfg_name: model_audit.mnfg_name)) %>
              </small>
            </td>

            <td class="table-cell-check">
              <%= check_mark if model_audit.manufacturer_other.present? %>
            </td>

            <td>
              <%= model_audit_frame_model_display(model_audit, truncate: true) %>
            </td>

            <td>
              <%= link_to number_display(model_audit.bikes_count), admin_bikes_path(search_model_audit_id: model_audit.id) %>
            </td>

            <td>
              <% model_audit.organization_model_audits.where.not(bikes_count: 0).pluck(:bikes_count, :organization_id).each do |bikes_count, org_id| %>
                <a
                  class="small"
                  href="<%= organization_model_audits_path(organization_id: org_id, model_audit_id: model_audit.id) %>"
                >
                  <%= org_names_hash[org_id] %>:
                  <%= number_display(bikes_count) %>
                </a>
              <% end %>
            </td>

            <td>
              <%= number_display(model_audit.model_attestations.count) %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
