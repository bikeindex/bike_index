<% table_view = capture do %>
  <% if params[:search_model_audit_id].present? %>
    <p>
      Viewing only Searches <strong>for</strong>
      <em><%= model_audit_frame_model_display(@model_audit, truncate: false) %></em>
      
      <%= link_to "view for all model audits", url_for(sortable_search_params.merge(search_model_audit_id: nil)), class: "gray-link small" %>
    </p>
  <% end %>

  <%= render partial: "/admin/model_attestations/table", locals: {collection: @model_attestations, render_sortable: true} %>
<% end %>

<%= render(Admin::IndexSkeleton::Component.new(
  collection: @model_attestations,
  viewing: "Model Attestations",
  table_view:,
  chart_collection: @render_chart && matching_model_attestations
)) %>
