<% nav_header_list_items = capture do %>
  <% if current_organization.present? %>
    <li class="nav-item">
      <span class="nav-link">
        <%= link_to current_organization.name, admin_organization_path(current_organization) %> Exports
        <small>
          <%= link_to "view orgs view", organization_exports_path(organization_id: current_organization.to_param), class: "less-strong" %>
        </small>
      </span>
    </li>
  <% end %>
  <li class="nav-item">
    <%= link_to "Deleted", url_for(sortable_search_params.merge(search_deleted: !@deleted)), class: "nav-link #{@deleted ? 'active' : ''}" %>
  </li>
<% end %>

<% table_view = render(partial: "table", locals: {collection: @collection, render_sortable: true}) %>

<%= render(Admin::IndexSkeleton::Component.new(
  viewing: "Exports",
  nav_header_list_items:,
  table_view:,
  chart_collection: @render_chart && matching_exports
)) %>
