<% nav_header_list_items = capture do %>
  <li class="nav-item dropdown dropleft small">
    <a
      class="nav-link dropdown-toggle <%= @search_permissions.present? ? "active" : "" %>"
      href="#"
      role="button"
      data-toggle="dropdown"
      aria-haspopup="true"
      aria-expanded="false"
    >
      <% if @search_permissions.blank? %>
        All Strava permissions
      <% else %>
        <%= @search_permissions.humanize %>
      <% end %>
    </a>

    <div class="dropdown-menu">
      <%= link_to "All permissions", url_for(sortable_search_params.merge(search_permissions: nil)), class: "dropdown-item #{@search_permissions.blank? ? 'active' : ''}" %>

      <div class="dropdown-divider"></div>

      <% permission_levels.each do |permissions_level| %>
        <%= link_to "#{permissions_level.humanize} permissions", url_for(sortable_search_params.merge(search_permissions: permissions_level)), class: "dropdown-item tw:text-left #{@search_permissions == permissions_level ? 'active' : ''}" %>
      <% end %>
    </div>
  </li>

  <li class="nav-item">
    <% if @render_deleted %>
      <%= link_to "Hide deleted", url_for(sortable_search_params.except(:search_deleted)), class: "nav-link active" %>
    <% else %>
      <%= link_to "Show deleted", url_for(sortable_search_params.merge(search_deleted: true)), class: "nav-link" %>
    <% end %>
  </li>
<% end %>

<% table_view = render(partial: "table", locals: {collection: @collection, render_sortable: true, render_deleted: @render_deleted}) %>
<%= render(Admin::IndexSkeleton::Component.new(nav_header_list_items:, chart_collection: @render_chart && matching_strava_integrations, table_view:)) %>
