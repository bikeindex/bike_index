<div class="tw:mb-6 tw:flex tw:items-center tw:justify-between">
  <h1>
    Registration sequence
    <small class="less-strong"><%= @registration_sequence.organization&.name %></small>
  </h1>

  <%= form_with url: admin_registration_sequence_path(@registration_sequence), method: :patch do %>
    <%= render UI::Button::Component.new(text: "Make this active", color: :primary, kind: :submit,
      data: {turbo_confirm: "Make this the active registration sequence for #{@registration_sequence.organization&.name}?"}) %>
  <% end %>
</div>

<% if @registration_sequence.organization.present? %>
  <%= link_to "View on the organization", organization_registration_sequence_path(organization_id: @registration_sequence.organization.to_param, id: @registration_sequence.id), class: "twlink" %>
<% end %>
