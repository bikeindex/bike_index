.admin-subnav
  %h1
    New Bulk Import

.row
  .col-sm-6
    = form_for [:admin, @bulk_import] do |f|
      = render(Alerts::ObjectErrors::Component.new(object: @bulk_import))

      .form-group
        = render Form::Combobox::Component.new(name: :organization_id, form: f, label: BulkImport.human_attribute_name(:organization_id), placeholder: "Choose organization", required: true, include_blank: true, options: Organization.all.pluck(:name, :id))
      .form-group
        .input-group
          .custom-file
          = f.label :file, "CSV", class: "custom-file-label"
          = f.file_field :file, class: "custom-file-input"
      .form-group
        = f.label :no_notify do
          = f.check_box :no_notify
          Don't send emails to registrations
      .form-group
        = f.label :no_duplicate do
          = f.check_box :no_duplicate
          Skip registering bikes with the same serial number as other bikes owned by the same email


      = f.submit 'Create', class: "btn btn-success float-right"
