<% signed_in_user ||= nil %>
<% ownership = bike.current_ownership %>
<% skip_to_see ||= false %>

<p>
  <% if OrganizationDisplayer.avatar?(ownership.organization) %>
    <%= image_tag ownership.organization.avatar.url(:medium), alt: ownership.organization.name, class: "claim-message-org-avatar" %>
  <% end %>

  <strong>
    <% if ownership.organization.present? %>
      <%= ownership.organization.name %>
    <% elsif ownership.creator&.name.present? %>
      <%= ownership.creator.name %>
    <% else %>
      <%= EmailNormalizer.obfuscate(ownership&.creator&.email) %>
    <% end %>
  </strong>

  <%= t(".registered_your_bike_on_index", bike_type: bike.type) %>
</p>

<p>
  <%= t(".public_resource_reunited_value_html", value: as_currency(Counts.recoveries_value)) %>
</p>

<p><%= t(".supercharge_if_your_bike_stolen", bike_type: bike.type) %></p>

<% unless skip_to_see %>
  <p>
    <% sign_up = t(".sign_up") %>
    <% sign_up_url = new_user_url(email: ownership.owner_email, return_to: bike_path(bike, t: ownership.token, email: ownership.owner_email)) %>
    <%= t(".to_see_your_bike_sign_up_html", bike_type: bike.type, sign_up_link: link_to(sign_up, sign_up_url)) %>
  </p>
<% end %>
