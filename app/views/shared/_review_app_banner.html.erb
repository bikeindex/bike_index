<% if ENV["REVIEW_APP"].present? %>
  <div class="tw:bg-yellow-300 tw:text-black tw:text-center tw:py-2 tw:px-4 tw:font-semibold tw:border-b tw:border-yellow-500">
    Review app
    <% if ENV["REVIEW_APP_PR_NUMBER"].present? %>
      &mdash;
      <a
        class="tw:underline"
        href="https://github.com/bikeindex/bike_index/pull/<%= ENV["REVIEW_APP_PR_NUMBER"] %>"
        target="_blank"
        rel="noopener"
      >PR #<%= ENV["REVIEW_APP_PR_NUMBER"] %></a>
    <% end %>
    &middot; not production, data is ephemeral
  </div>
<% end %>
