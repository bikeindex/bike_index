<div
  class="
    tw:flex tw:min-h-[60vh] tw:flex-col tw:items-center tw:justify-center
    tw:px-4 tw:text-center
  "
>
  <h1 class="lg:tw:mb-10 tw:mb-6 tw:text-3xl tw:font-bold">Bike Index Strava Search</h1>

  <p class="lg:tw:mb-6 tw:mb-4 tw:max-w-lg tw:text-lg tw:text-gray-600">
    Associate your Strava gear with your Bike Index registrations. Search,
    filter, and bulk-update your activities to assign gear to rides that are
    missing it.
  </p>

  <p class="lg:tw:mb-16 tw:mb-10 tw:max-w-lg tw:text-gray-500">
    Connect your Strava account to get started.
  </p>

  <%= link_to @connect_url do %>
    <%= image_tag("logos/btn_strava_connect.svg", alt: "Connect with Strava", style: "height: 48px; width: auto;") %>
  <% end %>
</div>
