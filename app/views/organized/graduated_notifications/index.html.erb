<%# TODO: add translations %>

<%#
  no-cache: form lives outside the frame, so turbo_action="advance" submits
  snapshot form/URL mismatch — back-nav restores the broken state.
%>

<% content_for :header do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="organized-page-header">
  <h1>Graduated notifications</h1>
</div>

<% unless current_organization.deliver_graduated_notifications? %>
  <div class="row mt-5 mb-5">
    <div class="col-md-6">
      <div class="alert alert-info">
        <h3>Not delivering graduated notifications</h3>
        <%= current_organization.name %> doesn't have a notification time period
        set, <span class="text-warning">bikes are not being graduated.</span>
        <br>
        Please email
        <%= link_to "gavin@bikeindex.org", "mailto:gavin@bikeindex.org" %> to
        set up graduated notifications.
      </div>
    </div>
  </div>
<% end %>

<%#
  Preserve status/secondary in form's default hidden fields (@interpreted_params
  doesn't include them). Reads params, not @search_status, which is unset on
  non-turbo renders.
%>
<% form_interpreted_params = @interpreted_params.merge(search_status: params[:search_status], search_secondary: params[:search_secondary]).compact %>

<div class="mt-4">
  <%= render(Search::FormOrganized::Component.new(
    target_search_path: organization_graduated_notifications_path(organization_id: current_organization.to_param),
    target_frame: :graduated_notifications_results_frame,
    interpreted_params: form_interpreted_params
  )) %>
</div>

<div class="search-results-frame-wrapper">
  <%#
    When the results aren't rendered inline (the JS shell), give the frame a src
    so Turbo eager-loads the results in a separate request once it connects
  %>

  <%= turbo_frame_tag :graduated_notifications_results_frame,
    src: (request.original_fullpath unless @render_results) do %>
    <div class="tw:mt-4">
      <%= render UI::PeriodSelect::Component.new(period: @period, start_time: @start_time, end_time: @end_time) %>
    </div>

    <div class="tw:mt-2 tw:text-right">
      <%= link_to "Render chart",
        organization_graduated_notifications_path(sortable_search_params.merge(organization_id: current_organization.to_param, render_chart: !@render_chart)),
        class: "btn btn-sm btn-outline-secondary #{"active" if @render_chart}",
        data: {turbo_action: "advance"} %>
    </div>

    <% if @render_results %>
      <%= render partial: "results" %>
    <% else %>
      <%#
        Hidden until JS reveals it - without JS the eager src never loads, so a
        no-JS user would otherwise be stuck on a spinner that never resolves
      %>
      <div hidden data-search-loading>
        <%= render UI::LoadingSpinner::Component.new(text: "Loading results...") %>
      </div>
    <% end %>
  <% end %>

  <div class="search-loading-overlay">
    <%= render UI::LoadingSpinner::Component.new(text: "Loading results...") %>
  </div>
</div>
