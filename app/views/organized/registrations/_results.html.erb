<% if @render_chart %>
  <%= turbo_frame_tag :organized_bikes_chart_frame,
    src: organization_registrations_path(sortable_search_params.merge(organization_id: current_organization.to_param, chart_only: "1")),
    loading: :lazy,
    class: "tw:flex tw:min-h-[300px] tw:items-center tw:justify-center" do %>
    <%= render UI::LoadingSpinner::Component.new(text: t(".loading_chart")) %>
  <% end %>
<% end %>

<%= render(Org::RegistrationSearch::Component.new(
  organization: current_organization,
  current_user:,
  pagy: @pagy,
  bikes: @bikes,
  interpreted_params: @interpreted_params,
  sortable_search_params:,
  per_page: @per_page,
  params:,
  search_stickers: @search_stickers,
  search_address: @search_address,
  search_status: @search_status,
  search_query_present: @search_query_present,
  time_range: @time_range,
  stolenness: @stolenness,
  bike_sticker: @bike_sticker,
  model_audit: @model_audit,
  skip_search_and_filters: true,
  skip_settings: true
)) %>
