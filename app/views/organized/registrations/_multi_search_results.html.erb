<div
  class="multi-search-serial-result"
  id="result_<%= @serial_chip_id&.delete_prefix("chip_") %>"
  data-serial-index="<%= @serial_chip_id&.delete_prefix("chip_") %>"
  data-result-count="<%= @pagy.count %>"
>
  <h4 class="uncap tw:mt-4 tw:mb-0 tw:px-1">
    Serial: <span class="serial-span"><%= @serial %></span>
    <span class="tw:text-sm tw:font-normal tw:text-gray-500">— <%= number_display(@pagy.count) %> <%= "result".pluralize(@pagy.count) %> <% if @pagy.count > 10 %>— first 10 shown,<%= link_to " view all",
          organization_registrations_path(organization_id: current_organization.to_param, search_serial: @serial),
          class: "twlink", data: {turbo_frame: "_top"} %><% end %></span>
  </h4>

  <% if @bikes.any? %>
    <%= render(Org::RegistrationSearch::Component.new(
      organization: current_organization,
      pagy: @pagy,
      bikes: @bikes,
      interpreted_params: @interpreted_params,
      sortable_search_params:,
      per_page: @per_page,
      params:,
      search_query_present: true,
      skip_search_and_filters: true,
      skip_settings: true,
      skip_count: true
    )) %>
  <% elsif @close_serials&.any? %>
    <p class="tw:text-gray-500">No exact matches. Close serials:</p>
    <ul class="tw:flex tw:list-none tw:flex-wrap tw:gap-2 tw:p-0">
      <% @close_serials.each do |bike| %>
        <li>
          <a href="<%= bike_path(bike) %>" class="twlink">
            <%= bike.serial_number %>
          </a>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="tw:text-gray-500">No matches found</p>
  <% end %>
</div>
