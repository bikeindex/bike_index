<% settings = Org::RegistrationSearchSettings::Component.new(
  organization: current_organization,
  skip_search_and_filters: true
) %>

<% search_kind = params[:search_kind] == "stickers" ? "stickers" : "serials" %>

<div
  data-controller="org--multi-serial-search org--registration-search org--registration-search-column-toggle"
  data-org--multi-serial-search-url-value="<%= multi_search_response_organization_registrations_path(organization_id: current_organization.to_param) %>"
  data-org--multi-serial-search-sticker-url-value="<%= multi_search_sticker_response_organization_registrations_path(organization_id: current_organization.to_param) %>"
  data-org--multi-serial-search-search-kind-value="<%= search_kind %>"
  data-org--multi-serial-search-empty-class-value="<%= UI::Badge::Component.badge_classes(color: :empty, size: :md) %>"
  data-org--multi-serial-search-success-class-value="<%= UI::Badge::Component.badge_classes(color: :success, size: :md) %>"
  data-org--multi-serial-search-gray-class-value="<%= UI::Badge::Component.badge_classes(color: :gray, size: :md) %>"
  data-org--multi-serial-search-spinner-value="<%= ERB::Util.html_escape(render(UI::LoadingSpinner::Component.new(size: :sm)).to_str) %>"
  data-org--registration-search-column-toggle-default-columns-value="<%= settings.initially_checked_columns.to_json %>"
>
  <div class="tw:mx-auto tw:mb-6 tw:max-w-2xl">
    <h3 class="uncap tw:mb-4">Multi Search</h3>

    <% if current_organization.enabled?("bike_stickers") %>
      <div class="tw:flex tw:gap-0 tw:mb-4" data-org--multi-serial-search-target="toggleGroup">
        <%= render UI::Button::Component.new(
          text: "Serials",
          color: :secondary,
          size: :md,
          active: search_kind == "serials",
          html_class: "tw:rounded-r-none!",
          data: {
            "org--multi-serial-search-target": "serialsToggle",
            action: "click->org--multi-serial-search#switchToSerials"
          }
        ) %>
        <%= render UI::Button::Component.new(
          text: "Bike Stickers",
          color: :secondary,
          size: :md,
          active: search_kind == "stickers",
          html_class: "tw:rounded-l-none! tw:border-l-0!",
          data: {
            "org--multi-serial-search-target": "stickersToggle",
            action: "click->org--multi-serial-search#switchToStickers"
          }
        ) %>
      </div>
    <% end %>

    <form data-action="submit->org--multi-serial-search#submit">
      <%= text_area_tag :serials, nil,
        placeholder: search_kind == "stickers" ? "Enter multiple sticker codes, separated by commas or new lines" : "Enter multiple serial numbers, separated by commas or new lines",
        class: "twinput tw:w-full tw:font-mono tw:h-32 tw:resize-none",
        data: {"org--multi-serial-search-target": "textarea"} %>

      <div class="tw:mt-2 tw:flex tw:justify-end">
        <%= render UI::Button::Component.new(
          text: search_kind == "stickers" ? "Search stickers" : "Search serials",
          color: :primary,
          size: :lg,
          kind: :submit,
          data: {"org--multi-serial-search-target": "button"}
        ) %>
      </div>
    </form>
  </div>

  <div
    data-org--multi-serial-search-target="serialChips"
    class="tw:mb-4 tw:flex tw:flex-wrap tw:gap-3"
  ></div>

  <div data-org--multi-serial-search-target="settingsContainer">
    <%= render settings %>
  </div>

  <div id="multi_serial_results" data-org--multi-serial-search-target="results"></div>
</div>
