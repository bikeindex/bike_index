<%= turbo_stream.append :multi_serial_results do %>
  <%= render partial: "multi_search_results" %>
<% end %>

<% if @serial_chip_id %>
  <%= turbo_stream.replace @serial_chip_id do %>
    <%= render Search::MultiResultChip::Component.new(
      serial: @serial,
      serial_chip_id: @serial_chip_id,
      result_count: @pagy.count
    ) %>
  <% end %>
<% end %>
