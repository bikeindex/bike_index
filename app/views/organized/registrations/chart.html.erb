<%= render(UI::Chart::AsyncFrame::Component.new(id: :registrations_chart_frame)) do %>
  <% if @available_bikes.present? %>
    <%= render(UI::Chart::Component.new(
      series: time_range_counts(collection: @available_bikes.unscope(:order), column: "bikes.created_at"),
      time_range: @time_range,
      stacked: true
    )) %>
  <% end %>
<% end %>
