<div class="tw:mx-auto tw:max-w-3xl tw:py-6">
  <h1 class="uncap tw:mb-6 tw:text-2xl tw:font-semibold">
    Registration sequences
  </h1>

  <h2 class="uncap tw:mb-2 tw:text-lg tw:font-semibold">Current</h2>

  <% if @active.present? %>
    <p class="tw:mb-2 tw:text-gray-600">
      This is the active version your registrants see.
    </p>
  <% else %>
    <p class="tw:mb-2 tw:text-gray-600">
      There is no active registration sequence.
    </p>
    <p class="tw:mb-2 tw:text-gray-600">
      Edit your draft sequence and contact Bike Index when you're ready to make
      it live.
    </p>
  <% end %>

  <h2 class="uncap tw:mb-2 tw:text-lg tw:font-semibold">Draft</h2>

  <p class="tw:mb-2 tw:text-gray-600">
    <% if @draft.present? %>
      Your draft sequence, last edited
      <span class="localizeTime preciseTime">
        <%= l @draft.updated_at, format: :convert_time %>
      </span>
    <% else %>
      You haven't started a draft sequence yet.
    <% end %>
  </p>

  <%= button_to "Edit sequence", organization_registration_sequences_path(organization_id: current_organization.to_param), method: :post, class: "twlink", form_class: "tw:mb-6 tw:inline-block" %>
</div>
