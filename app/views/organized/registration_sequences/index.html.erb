<div class="tw:mx-auto tw:max-w-3xl tw:py-6">
  <div class="tw:mb-6 tw:flex tw:items-center tw:justify-between">
    <h1 class="uncap tw:text-2xl tw:font-semibold">Registration sequences</h1>

    <% if @draft.present? %>
      <%= render UI::ButtonLink::Component.new(text: "Manage draft pages",
        href: organization_registration_sequence_path(organization_id: current_organization.to_param, id: @draft.id),
        color: :primary) %>
    <% end %>
  </div>

  <h2 class="uncap tw:mb-2 tw:text-lg tw:font-semibold">Current</h2>

  <% if @active.present? %>
    <p class="tw:text-gray-600">
      This is the active version your registrants see.
      <%= link_to "Preview", organization_registration_sequence_path(organization_id: current_organization.to_param, id: @active.id), class: "twlink" %>
    </p>
  <% else %>
    <p class="tw:text-gray-600">
      There is no active registration sequence.
    </p>
    <p class="tw:text-gray-600">
      Edit your draft sequence and contact Bike Index when you're ready to make
      it live.
    </p>
  <% end %>

  <h2 class="uncap tw:mb-2 tw:text-lg tw:font-semibold">Draft</h2>

  <p class="tw:text-gray-600">
    <% if @draft.present? %>
      Your draft sequence, last edited
      <span class="localizeTime preciseTime">
        <%= l @draft.updated_at, format: :convert_time %>
      </span>
    <% else %>
      You haven't started a draft sequence yet.
    <% end %>
  </p>

  <%= button_to "Edit sequence", organization_registration_sequences_path(organization_id: current_organization.to_param), method: :post, class: "twlink", form_class: "tw:mb-6 tw:inline-block" %>

  <% if @previous.any? %>
    <h2 class="uncap tw:mb-2 tw:text-lg tw:font-semibold">Previous</h2>
    <ul class="tw:list-none tw:text-gray-600">
      <% @previous.each do |registration_sequence| %>
        <li class="tw:mb-1">
          <%= link_to "Preview", organization_registration_sequence_path(organization_id: current_organization.to_param, id: registration_sequence.id), class: "twlink" %>
          ended
          <span class="localizeTime"><%= l registration_sequence.end_at, format: :convert_time %></span>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
