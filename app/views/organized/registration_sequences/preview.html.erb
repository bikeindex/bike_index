<div class="tw:mx-auto tw:max-w-3xl tw:py-6">
  <h1 class="tw:mb-6 tw:text-2xl tw:font-semibold">
    Preview
    <span class="tw:text-base tw:font-normal tw:text-gray-500"><%= (params[:version] == "live") ? "(live version)" : "(upcoming version)" %></span>
  </h1>

  <% if @registration_sequence.present? %>
    <%= render RegistrationSequencePreview::Component.new(registration_sequence: @registration_sequence) %>
  <% else %>
    <p class="tw:text-gray-600">Nothing to preview yet.</p>
  <% end %>
</div>
