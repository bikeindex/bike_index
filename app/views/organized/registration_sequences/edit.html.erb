<% content_for(:header) { stylesheet_link_tag "lexxy", "data-turbo-track": "reload" } %>

<div class="tw:mx-auto tw:max-w-3xl tw:py-6">
  <div class="tw:mb-6 tw:flex tw:items-center tw:justify-between">
    <h1 class="tw:text-2xl tw:font-semibold">
      Edit draft registration sequence
    </h1>

    <div class="tw:flex tw:gap-3">
      <%= link_to "Preview draft", organization_registration_sequence_path(organization_id: current_organization.to_param, registration_sequence_id: @draft.id), class: "twlink", target: "_blank" %>
      <%= link_to "View all", organization_registration_sequences_path(organization_id: current_organization.to_param), class: "twlink" %>
    </div>
  </div>

  <p class="tw:mb-6 tw:text-gray-600">
    Each page shows an image and rich text content. Changes stay in this draft
    version until a Bike Index admin authorizes it to go live.
  </p>

  <%= form_with model: @draft,
    url: organization_registration_sequence_path(organization_id: current_organization.to_param, registration_sequence_id: @draft.id),
    method: :patch, html: {multipart: true}, data: {controller: "nested-form"} do |f| %>
    <div data-nested-form-target="list" class="tw:flex tw:flex-col tw:gap-4">
      <%= f.fields_for :registration_sequence_pages do |page_form| %>
        <%= render Org::RegistrationSequencePageFields::Component.new(form_builder: page_form) %>
      <% end %>
    </div>

    <template data-nested-form-target="template">
      <%= f.fields_for :registration_sequence_pages, RegistrationSequencePage.new, child_index: "NEW_RECORD" do |page_form| %>
        <%= render Org::RegistrationSequencePageFields::Component.new(form_builder: page_form) %>
      <% end %>
    </template>

    <div class="tw:mt-4 tw:flex tw:items-center tw:justify-between">
      <%= render UI::Button::Component.new(text: "Add a page", color: :secondary, data: {action: "nested-form#add"}) %>

      <%= render UI::Button::Component.new(text: "Save draft version", color: :primary, kind: :submit) %>
    </div>
  <% end %>
</div>
