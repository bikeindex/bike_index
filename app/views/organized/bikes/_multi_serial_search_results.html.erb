<div class="tw:mb-6">
  <h4>
    Serial: <code><%= @serial %></code>
    <span class="tw:text-sm tw:font-normal tw:text-gray-500">
      — <%= @pagy.count %> <%= "result".pluralize(@pagy.count) %>
    </span>
  </h4>

  <% if @bikes.any? %>
    <% bike_search = Org::BikeSearch::Component.new(
      organization: current_organization,
      pagy: @pagy,
      interpreted_params: @interpreted_params,
      sortable_search_params:,
      per_page: @per_page,
      params:,
      search_query_present: true,
      skip_search_and_filters: true,
      skip_settings: true
    ) %>

    <%= render(bike_search) do %>
      <% @bikes.each do |bike| %>
        <%= render partial: "cached_bike_table_row", locals: {bike:, bike_search:} %>
      <% end %>
    <% end %>
  <% elsif @close_serials&.any? %>
    <p class="tw:text-gray-500">No exact matches. Close serials:</p>
    <ul class="tw:list-none tw:p-0 tw:flex tw:flex-wrap tw:gap-2">
      <% @close_serials.each do |bike| %>
        <li>
          <a href="<%= bike_path(bike) %>" class="twlink"><%= bike.serial_number %></a>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="tw:text-gray-500">No matches found</p>
  <% end %>
</div>
