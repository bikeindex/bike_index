<div class="organized-exports">
  <div class="organized-page-header">
    <h1>
      <%= t(".exports") %>

      <% if @export.finished? %>
        <small>
          <%= link_to t(".download_export"), @export.file.url, class: "btn btn-secondary pull-right" %>
        </small>
      <% end %>
    </h1>
  </div>

  <% if @avery_export_redirect %>
    <%= render UI::Alert::Component.new(text: t(".shared_alert_body"), kind: :success) %>
  <% end %>

  <% if @export.deleted_at.present? %>
    <% deleted_time = content_tag(:span, l(@export.deleted_at, format: :convert_time), class: "localizeTime preciseTime withPreposition") %>
    <%= render(UI::Alert::Component.new(kind: :error)) do %>
      This export was deleted <%= deleted_time %>
    <% end %>
  <% end %>

  <table class="table-list">
    <tbody>
      <tr>
        <td><%= t(".created") %></td>

        <td>
          <span class="localizeTime preciseTime">
            <%= l(@export.created_at, format: :convert_time) %>
          </span>
        </td>
      </tr>

      <tr>
        <td><%= t(".by") %></td>
        <td><%= @export.user.display_name if @export.user.present? %></td>
      </tr>

      <tr>
        <td><%= t(".format") %></td>
        <td><%= @export.file_format %></td>
      </tr>

      <tr>
        <td><%= t(".progress") %></td>

        <td
          id="exportProgress"
          class="<%= @export.progress %>"
          data-createdat="<%= @export.created_at.to_i %>"
        >
          <span class="<%= export_progress_class(@export) %>">
            <%= @export.calculated_progress %>
          </span>
        </td>
      </tr>

      <% if current_organization.enabled?("show_partial_registrations") || @export.impounded_bikes %>
        <tr>
          <td><%= t(".registration_types") %></td>

          <td>
            <%= @export.matching_kinds.map { |k| k.to_s.humanize(capitalize: false) }.join(" & ").capitalize %>
          </td>
        </tr>
      <% end %>

      <tr>
        <td><%= t(".bikes_exported") %></td>

        <td>
          <%= @export.rows %>
          <% bike_ids = @export.exported_bike_ids %>

          <% if bike_ids.present? %>
            <a
              class="small less-strong"
              href="#show_exported_bikes"
              aria-controls="show_exported_bikes"
              data-toggle="collapse"
            >
              <% unless @export.only_custom_bike_ids %>
                <% if @export&.rows.to_i > 100 %>
                  <%= t(".show_first_100_bikes_in_export") %>
                <% else %>
                  <%= t(".show_bikes_in_export") %>
                <% end %>
              <% end %>
            </a>
            <div class="collapse" id="show_exported_bikes">
              <ul class="exported-link-list">
                <% bike_ids.each_with_index do |id, i| %>
                  <li>
                    <%= link_to id, bike_path(id, organization_id: current_organization.to_param) %><%= i == (@export.exported_bike_ids.count - 1) ? "" : "," %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </td>
      </tr>

      <% unless @export.only_custom_bike_ids %>
        <tr>
          <td><%= t(".bikes_registered_after") %></td>

          <td>
            <% if @export.start_at.present? %>
              <span class="localizeTime preciseTime">
                <%= l(@export.start_at, format: :convert_time) %>
              </span>
            <% else %>
              <small class="less-strong">-</small>
            <% end %>
          </td>
        </tr>
        <tr>
          <td><%= t(".bikes_registered_before") %></td>

          <td>
            <% if @export.end_at.present? %>
              <span class="localizeTime preciseTime">
                <%= l(@export.end_at, format: :convert_time) %>
              </span>
            <% else %>
              <small class="less-strong">-</small>
            <% end %>
          </td>
        </tr>
      <% end %>

      <% if @export.custom_bike_ids.present? %>
        <tr>
          <td><%= t(".specific_bikes") %></td>

          <td>
            <% if @export.only_custom_bike_ids %>
              <small class="d-block mb-1">
                Only these specific bikes are included in this export:
              </small>
            <% end %>

            <% included_bike_ids = @export.custom_bike_ids & @export.bikes_scoped.pluck(:id) %>

            <div style="max-height: 300px; overflow-x: scroll;">
              <ul class="mb-0 row">
                <% @export.custom_bike_ids.each do |custom_id| %>
                  <li class="col-md-4 col-xs-6">
                    <% if included_bike_ids.include?(custom_id) %>
                      <%= link_to custom_id, bike_path(custom_id, organization_id: current_organization.to_param) %>
                    <% else %>
                      <small class="text-warning">
                        <%= link_to(custom_id, bike_path(custom_id, organization_id: current_organization.to_param), class: "less-strong text-warning text-underline") %>:
                        <em><%= t(".unable_to_export") %></em>
                      </small>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @export.avery_export? %>
        <tr>
          <td><%= t(".avery_export") %></td>

          <td>
            <% if @export.finished? %>
              <strong>
                <%= link_to(t(".view_avery_labels"), @export.avery_export_url, class: "avery_export_url") %>
              </strong>
            <% else %>
              <em class="text-success"><%= t(".pending") %></em>
            <% end %>
          </td>
        </tr>
      <% end %>

      <% if @export.assign_bike_codes? || @export.avery_export? %>
        <tr>
          <td><%= t(".stickers") %></td>

          <td>
            <% if @export.assign_bike_codes? %>
              <em>
                <%= t(".stickers_exported", bike_stickers_count: @export.bike_stickers_assigned&.count.to_i) %>
              </em>
              <% if @export.bike_stickers_assigned.any? %>
                <ul class="exported-link-list">
                  <% @export.bike_stickers_assigned.each_with_index do |code, i| %>
                    <li>
                      <%= link_to code, edit_organization_sticker_path(code, organization_id: current_organization.to_param) %><%= i == (@export.bike_stickers_assigned.count - 1) ? "" : "," %>
                    </li>
                  <% end %>
                </ul>
                <% if @export.bike_codes_removed? %>
                  <em class="text-danger">
                    <%= t(".stickers_have_been_unassigned") %>
                  </em>
                <% else %>
                  <%= link_to(t(".unassign_stickers"),
                    organization_export_path(@export.id, organization_id: current_organization.to_param, remove_bike_stickers: true),
                    method: :put,
                    class: "btn btn-warning float-right") %>
                <% end %>
              <% else %>
                <small class="less-strong">
                  <%= t(".no_stickers_assigned") %>
                </small>
              <% end %>
            <% else %>
              <%= t(".not_assigned") %>
            <% end %>
          </td>
        </tr>
      <% end %>

      <tr>
        <td><%= t(".columns_in_csv") %></td>

        <td>
          <ul class="mb-0">
            <% @export.written_headers.each do |header| %>
              <li><%= header.humanize(keep_id_suffix: true) %></li>
            <% end %>
          </ul>
        </td>
      </tr>
    </tbody>
  </table>
</div>
