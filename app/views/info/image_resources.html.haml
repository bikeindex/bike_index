= content_for :header do
  = stylesheet_link_tag "kelsey_styles", "data-turbo-track" => "reload"

.kelsey_styles
  %section.le-hero-section
    %div.le-bike-tiles-grid{"data-controller" => "landing-pages--bike-tiles", "data-landing-pages--bike-tiles-target" => "grid", "data-landing-pages--bike-tiles-images-value" => @bike_tile_images.to_json}
    .le-hero-content
      %h1 Resources & Marketing Materials
      %p.le-hero-tagline
        Bike Index is meant to be usable and expandable by everyone. We're way into the open source.
      .le-hero-buttons
        = link_to "Design Resources", "#design-resources", class: "le-btn-primary"
        = link_to "Development Resources", "#dev-resources", class: "le-btn-primary"

  %section#design-resources.resources-section
    .container
      %h2 Design Resources
      %p.resources-intro Free downloadable resources to help promote Bike Index in your community.
      .resources-grid
        - @design_resources.each do |resource|
          .resource-card
            .resource-thumbnail
              = image_tag resource[:thumbnail], alt: resource[:title]
            .resource-content
              %h3= resource[:title]
              %p= resource[:description]
              = link_to resource[:button_text], resource[:file], class: "resource-btn", download: ""

  %section#dev-resources.resources-section.dev-resources-section
    .container
      %h2 Development Resources
      %p.resources-intro Build on top of Bike Index with our open source code and APIs.
      .dev-resources-list
        - @dev_resources.each do |resource|
          .dev-resource-item
            .dev-resource-content
              %h3= resource[:title]
              %p= resource[:description]
              = link_to "#{resource[:link_text]} →", resource[:url], class: "dev-resource-link", target: "_blank", rel: "noopener noreferrer"

  %section.le-cta-section
    .container
      %h2 Questions about using these resources?
      %p.le-cta-subtitle
        We're here to help you spread the word about Bike Index in your community.
      %p.le-nonprofit-message
        We're a 501(c)(3) non-profit. Our mission is bike theft recovery, not profit.
      .le-cta-buttons
        = link_to "Get in Touch", "mailto:contact@bikeindex.org", class: "le-btn-primary"
