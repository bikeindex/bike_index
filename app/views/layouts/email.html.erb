<!DOCTYPE html>

<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

    <title>
      <%= content_for?(:title) ? yield(:title) : t(".bike_index") %>
    </title>

    <%= stylesheet_link_tag "email" %>

    <%# Remove the top and bottom margin on email preview, because they look funky %>
    <% if @email_preview %>
      <style>
        .binx-wrapper { margin: 0; }
        html { background: #e6e6e6; }
      </style>
    <% end %>
  </head>

  <body>
    <div class="binx-wrapper">
      <% if @email_sent_at.present? %>
        <%= stylesheet_link_tag "tailwind" %>
        <% if @email_sent_at >= MailSnippet::PAPER_TRAIL_TRACKING_STARTED_AT %>
          <%= render(UI::Alert::Component.new(kind: :notice, margin_classes: "", text: "this is the version that was shown to the user, not the current version")) %>
        <% else %>
          <%= render(UI::Alert::Component.new(kind: :warning, margin_classes: "", text: "This was sent before we tracked versions, so it may not match what the user saw (if you edited your custom email)")) %>
        <% end %>
      <% end %>

      <% unless @skip_header %>
        <% if @partner %>
          <table class="binx-header">
            <tbody>
              <tr>
                <td class="partner-header">
                  <span class="partner-logo-wrapper">
                    <%= image_tag "https://files.bikeindex.org/email_assets/bikehub_logo_plus.png",
                      height: "50",
                      class: "partner-header-logo" %>
                  </span>

                  <img
                    class="bike-index-logo"
                    src="https://files.bikeindex.org/email_assets/logo.png"
                    height="70"
                    alt="Bike Index"
                  >
                </td>
              </tr>
            </tbody>
          </table>
        <% else %>
          <%# Shared blue banner header — the same hero banner finished_registration uses, so every email shares one header design %>
          <div class="binx-header-banner">
            <%= image_tag image_url("email_assets/finished_registration/bike-index-email-header.png"),
              alt: "Bike Index",
              class: "binx-header-banner-image" %>
          </div>
        <% end %>
      <% end %>

      <div class="binx-body">
        <%# We only render snippets for organized messages - or if we're doing a preview %>
        <% render_organization_snippets = @organization.present? && (controller_path == "organized_mailer" || @email_preview) %>
        <% header_snippet = render_organization_snippets ? @organization.mail_snippet_body("header", time: @email_sent_at) : nil %>
        <% footer_snippet = render_organization_snippets ? @organization.mail_snippet_body("footer", time: @email_sent_at) : nil %>

        <% if header_snippet.present? %>
          <%= header_snippet.html_safe %>
        <% end %>

        <%= yield %>

        <% if footer_snippet.present? %>
          <%= footer_snippet.html_safe %>
        <% end %>
      </div>

      <% unless @skip_postscript %>
        <div class="binx-pstscpt">
          <div class="hearts">
            <span>&#9829;</span>
            <span>&#9829;</span>
            <span>&#9829;</span>
            <span>&#9829;</span>
            <span>&#9829;</span>
          </div>

          <h4><%= t(".the_bike_index_team") %></h4>
        </div>
      <% end %>

      <% unless @skip_footer %>
        <div class="binx-footer">
          <h5>
            <% if render_donation?(@organization) %>
              <%= t(".help_prevent_theft") %>
              <%= link_to(t(".make_a_donation"), support_the_index_url) %>
            <% end %>
          </h5>

          <% if render_supporters?(@organization) %>
            <p>
              Bike Index is also supported by
              <%= link_to "Ottalaus", "https://ottalausinc.ca/" %> and
              <%= link_to "The Pro's Closet", "https://www.theproscloset.com/" %>.
            </p>
          <% end %>
        </div>
      <% end %>
    </div>
  </body>
</html>
