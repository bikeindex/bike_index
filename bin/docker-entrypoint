#!/bin/bash -e

# If running the rails server, provision the app's database role and run migrations.
# Bike Index uses two databases (primary + analytics) under the same role;
# `db:prepare` handles both via Rails multi-database support.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  if [ -n "$POSTGRES_PASSWORD" ] && [ -n "$POSTGRESQL_ADDRESS" ] && [ -n "$POSTGRESQL_USERNAME" ]; then
    echo "Ensuring database role '$POSTGRESQL_USERNAME' exists (SUPERUSER)..."
    # The per-PR role is a SUPERUSER. It loads production's db/structure.sql,
    # which creates AND comments the superuser-only pg_stat_statements extension
    # (COMMENT ON EXTENSION requires ownership and has no IF NOT EXISTS), and it
    # must own its tables for migrations/seeds. The shared review-app Postgres is
    # sandbox-only, ephemeral, no-PII, and separate from production (Cloud66), so
    # review apps not being isolated from each other on it is acceptable. See
    # docs/review-apps.md "Known limits".
    #
    # psql substitutes :'var' (quoted literal) only OUTSIDE dollar-quoted blocks,
    # so build the statements in plain SELECTs and run them with \gexec; format()'s
    # %I/%L quote the role name as an identifier and the password as a literal. The
    # CREATE runs only when the role is absent; the ALTER always runs, so a role
    # left over from an earlier (non-superuser) deploy is upgraded in place.
    PGPASSWORD="$POSTGRES_PASSWORD" psql -h "$POSTGRESQL_ADDRESS" -U postgres \
      -v ON_ERROR_STOP=1 \
      -v username="$POSTGRESQL_USERNAME" \
      -v password="$POSTGRESQL_PASSWORD" <<'SQL'
SELECT format('CREATE ROLE %I LOGIN PASSWORD %L', :'username', :'password')
WHERE NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = :'username')
\gexec
SELECT format('ALTER ROLE %I LOGIN SUPERUSER CREATEDB', :'username')
\gexec
SQL
  fi

  ./bin/rails db:prepare
fi

exec "${@}"
