#!/bin/bash -e

# If running the rails server, provision the app's database role and run migrations.
# Bike Index uses two databases (primary + analytics) under the same role;
# `db:prepare` handles both via Rails multi-database support.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  if [ -n "$POSTGRES_PASSWORD" ] && [ -n "$POSTGRESQL_ADDRESS" ] && [ -n "$POSTGRESQL_USERNAME" ]; then
    echo "Ensuring database role '$POSTGRESQL_USERNAME' exists..."
    # Check + create in one psql round-trip. psql substitutes :'var' (quoted
    # literal) only OUTSIDE dollar-quoted blocks, so build the CREATE ROLE in a
    # plain SELECT and run it with \gexec — a DO $$...$$ body would pass :'var'
    # through literally and error. format()'s %I/%L quote the role name as an
    # identifier and the password as a literal. The SELECT yields the statement
    # only when the role is absent, so an existing role is a no-op.
    PGPASSWORD="$POSTGRES_PASSWORD" psql -h "$POSTGRESQL_ADDRESS" -U postgres \
      -v ON_ERROR_STOP=1 \
      -v username="$POSTGRESQL_USERNAME" \
      -v password="$POSTGRESQL_PASSWORD" <<'SQL'
SELECT format('CREATE ROLE %I LOGIN PASSWORD %L CREATEDB', :'username', :'password')
WHERE NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = :'username')
\gexec
SQL
  fi

  ./bin/rails db:prepare
fi

exec "${@}"
