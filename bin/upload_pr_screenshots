#!/bin/bash
# Usage: bin/upload_pr_screenshots
# Uploads every PNG in tmp/pr_screenshots/ to the _pr-screenshots prerelease
# on the current repo (creating the prerelease on first use). Prints the
# public URL for each uploaded file.

set -eu

repo="$(gh repo view --json nameWithOwner -q .nameWithOwner)"
tag=_pr-screenshots

gh release view "$tag" --repo "$repo" >/dev/null 2>&1 \
  || gh release create "$tag" --repo "$repo" --prerelease \
       --title "PR screenshots" \
       --notes "Auto-uploaded PR screenshots — do not delete."

gh release upload "$tag" tmp/pr_screenshots/*.png --repo "$repo" --clobber

for f in tmp/pr_screenshots/*.png; do
  echo "https://github.com/${repo}/releases/download/${tag}/$(basename "$f")"
done
