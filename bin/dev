#!/bin/bash
touch log/development.log
> log/development.log # Clear out development log, otherwise it balloons
> log/test.log # Clear out test log too
touch log/bullet.log
> log/test.log # Clear out bullet log
# Clear out temp - mainly used by tests, preserve .txt toggle files (e.g. caching-dev.txt)
find tmp -mindepth 1 -not -name '*.txt' -delete 2>/dev/null

# Start Redis in the background, if it isn't started already
touch log/redis.log
> log/redis.log
redis-server > log/redis.log &

eval "$(ruby bin/env --export)"

# Pass --strava to start the strava_search Vite dev server
FOREMAN_ARGS="-f Procfile.dev"
if [[ " $* " == *" --strava "* ]]; then
  export BUILD_STRAVA_SEARCH=true
else
  FOREMAN_ARGS="$FOREMAN_ARGS -m all=1,strava_search=0"
fi

# If there is a development specific environment file
if test -f .env.development; then
  bundle exec foreman start $FOREMAN_ARGS --env .env.development
else
  bundle exec foreman start $FOREMAN_ARGS
fi
