#!/usr/bin/env bash
# Helper for deploying / destroying the persistent staging app.
#
# Called by .github/workflows/staging.yml. Can also be run locally if you have
# kamal installed and SSH access to the staging host.
#
#   bin/staging deploy  [<image_tag>]
#   bin/staging destroy
#
# Staging is single-tenant: one persistent service `bike-index-staging` at
# https://staging.bikeindex.org, copying production behavior except that
# DISABLE_EMAIL_DELIVERY=true short-circuits ActionMailer (see
# config/environments/production.rb).
#
# Kamal reads .kamal/secrets by default. CI populates it by copying
# .kamal/secrets-ci over the top before invoking this script.

set -euo pipefail

CONFIG="${KAMAL_CONFIG:-config/deploy.staging.yml}"
ROLE="bike_index_staging"
PRIMARY_DB="bike_index_staging_primary"
ANALYTICS_DB="bike_index_staging_analytics"

usage() {
  cat <<USAGE
Usage:
  bin/staging deploy  [<image_tag>]
  bin/staging destroy

Required env (set by the workflow or your shell):
  STAGING_HOST, KAMAL_REGISTRY_PASSWORD, POSTGRES_PASSWORD,
  and the rest of the secrets named in .kamal/secrets-ci.
USAGE
  exit 1
}

[[ $# -lt 1 ]] && usage
action="$1"
image_tag="${2:-${IMAGE_TAG:-}}"

export STAGING_HOST="${STAGING_HOST:?STAGING_HOST is required}"

kamal() { command kamal "$@" --config-file "$CONFIG"; }

case "$action" in
  deploy)
    : "${image_tag:?image_tag required (2nd arg or IMAGE_TAG env)}"
    export IMAGE_TAG="$image_tag"
    echo "==> Deploying staging at image tag $IMAGE_TAG"
    kamal deploy
    echo "==> Done. URL: https://staging.bikeindex.org"
    ;;

  destroy)
    echo "==> Destroying staging app"
    # IMAGE_TAG is required by the ERB even though we're tearing down.
    export IMAGE_TAG="${image_tag:-destroy}"

    kamal app remove || true

    echo "==> Dropping staging databases ($PRIMARY_DB, $ANALYTICS_DB) and role ($ROLE)"
    for sql in \
      "DROP DATABASE IF EXISTS ${PRIMARY_DB} WITH (FORCE)" \
      "DROP DATABASE IF EXISTS ${ANALYTICS_DB} WITH (FORCE)" \
      "DROP ROLE IF EXISTS ${ROLE}"
    do
      kamal accessory exec db --reuse \
        "psql -U postgres -d postgres -v ON_ERROR_STOP=1 -c \"${sql}\"" || true
    done

    echo "==> Flushing staging redis"
    kamal accessory exec redis --reuse "redis-cli -n 0 FLUSHDB" || true

    echo "==> Done."
    ;;

  *)
    usage
    ;;
esac
