#!/usr/bin/env ruby

# To test linting, rather than automatically fix it, set LINT_TEST
# NOTE: CI doesn't actually use bin/lint, it manually calls each of the commands for better output
#
cli_args = ARGV
lint_test = ENV["LINT_TEST"] == "true" || cli_args.include?("--no-fix")

# You can pass a file name to lint just that file
file_args = cli_args.reject { |arg| arg.start_with?("-") }

require "fileutils"

# path to your application root.
APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args) || abort("\n== Command #{args} failed ==")
end

FileUtils.chdir APP_ROOT do
  # lint_test checking doesn't accept file name
  if lint_test
    puts "Testing lint (will not autofix)"

    system!("bundle exec standardrb --no-fix")
    system!("bundle exec rubocop -c .rubocop_custom.yml")
    return system!("npm run lint_check")
  end

  if file_args.any?
    file_args.each do |file|
      # Assume bin/ files are ruby, since they mostly are
      if file.end_with?(".rb") || file.end_with?(".rake") || file.start_with?("bin/")
        system!("bundle exec standardrb --fix #{file}")
        system!("bundle exec rubocop -c .rubocop_custom.yml -A #{file}")
      elsif file.end_with?(".js", ".ts", ".jsx", ".tsx")
        system!("npm run js:lint -- #{file}")
      elsif file.end_with?(".erb", ".html")
        system!("npm run html:format -- #{file}")
      else
        raise "Unknown file type: #{file}"
      end
    end
  else
    system!("bundle exec standardrb --fix")
    system!("bundle exec rubocop -c .rubocop_custom.yml -A")
    system!("npm run lint")
  end
end
