#!/usr/bin/env ruby
# frozen_string_literal: true

# Assigns this checkout a workspace ID and writes it to .workspace_id at the
# repo root, then runs bin/setup. The ID is loaded by bin/env to populate
# WORKSPACE_ID. IDs are tracked in the local Postgres `dev_workspaces` database
# so multiple checkouts on the same machine each get a distinct ID.
#
# ID selection: reuse the lowest soft-deleted ID whose deleted_at is older than
# DELETED_REUSE_DELAY; otherwise allocate MAX(id) + 1 (floor 3072). The delay
# prevents recycling an ID while stale data tied to it may still be around.
#
# Any arguments passed to this script are forwarded to bin/setup.

require "fileutils"

APP_ROOT = Dir.pwd
WORKSPACE_FILE = File.join(APP_ROOT, ".workspace_id")
WORKSPACE_DB = "dev_workspaces"
DELETED_REUSE_DELAY = "3 weeks" # postgres interval

def psql(database, query)
  output = IO.popen(["psql", "-d", database, "-tAX", "-c", query], &:read)
  abort "psql failed for #{database}: #{query}" unless $?.success?
  output.strip
end

if File.exist?(WORKSPACE_FILE)
  puts "workspace ID already set: #{File.read(WORKSPACE_FILE).strip}"
else
  if psql("postgres", "SELECT 1 FROM pg_database WHERE datname = '#{WORKSPACE_DB}'").empty?
    system("createdb", WORKSPACE_DB) || abort("Failed to create database #{WORKSPACE_DB}")
  end

  psql(WORKSPACE_DB, "SET client_min_messages = WARNING; CREATE TABLE IF NOT EXISTS workspace_ids (id INTEGER PRIMARY KEY, deleted_at TIMESTAMP)")
  reusable = psql(WORKSPACE_DB, "SELECT id FROM workspace_ids WHERE deleted_at < NOW() - INTERVAL '#{DELETED_REUSE_DELAY}' ORDER BY id ASC LIMIT 1")
  if reusable.empty?
    next_id = psql(WORKSPACE_DB, "SELECT GREATEST(COALESCE(MAX(id) + 1, 3072), 3072) FROM workspace_ids").to_i
    psql(WORKSPACE_DB, "INSERT INTO workspace_ids (id) VALUES (#{next_id})")
  else
    next_id = reusable.to_i
    psql(WORKSPACE_DB, "UPDATE workspace_ids SET deleted_at = NULL WHERE id = #{next_id}")
  end
  File.write(WORKSPACE_FILE, next_id.to_s)
  puts "workspace ID set to #{next_id}"
end

system(File.join(APP_ROOT, "bin/setup"), *ARGV) || abort("bin/setup failed")
exec File.join(APP_ROOT, "bin/fix_structure")
