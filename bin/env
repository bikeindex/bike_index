#!/usr/bin/env ruby
# frozen_string_literal: true

# Default environment variables for development and test.
# Required from config/boot.rb so all Rails entry points get these defaults.
# Can also be run standalone: `eval "$(ruby bin/env --export)"` from bash.

workspace_file = File.expand_path("../.workspace_id", __dir__)
if File.exist?(workspace_file)
  workspace_int = File.read(workspace_file).strip
  ENV["WORKSPACE_ID"] ||= workspace_int
  ENV["DEV_PORT"] ||= workspace_int
end

ENV["DEV_PORT"] ||= "3042"
ENV["BASE_URL"] ||= "http://localhost:#{ENV["DEV_PORT"]}"

# Run Puma in single mode (0 workers, no fork) so Mata live-reload works: its
# file-watcher thread and SSE registry must live in the request-serving process.
# Only loaded for dev/test (see config/boot.rb); deployed envs set their own count.
ENV["WEB_CONCURRENCY"] ||= "0"

# Redis only has 16 databases (0-15). Reserve database 0 for the main checkout
# (no WORKSPACE_ID) so workspace dev servers can't clobber its data (eg the
# autocomplete cache). Workspaces share databases 1-15.
unless ENV["REDIS_URL"]
  redis_database = ENV["WORKSPACE_ID"] ? (ENV["WORKSPACE_ID"].to_i % 15) + 1 : 0
  ENV["REDIS_URL"] = "redis://localhost:6379/#{redis_database}"
end

# When called with --export, print shell export statements for bash scripts
if ARGV.include?("--export")
  %w[WORKSPACE_ID DEV_PORT BASE_URL REDIS_URL WEB_CONCURRENCY].each do |key|
    puts "export #{key}=#{ENV[key]}" if ENV[key]
  end
end
