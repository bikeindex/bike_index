# CI secrets file — all values come from GitHub Actions env vars.
# Kamal's Dotenv parser requires explicit assignments (no shell conditionals).
#
# Kamal always reads .kamal/secrets; CI copies this file over it before running
# kamal (see .github/workflows/review-app.yml "Stage CI secrets file").
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Postgres: admin password used by docker-entrypoint to create the per-app role,
# and the per-app DB password (same value — see bin/docker-entrypoint).
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
POSTGRESQL_PASSWORD=$POSTGRES_PASSWORD
ANALYTICS_DB_PASSWORD=$POSTGRES_PASSWORD

# App secrets
SECRET_KEY_BASE=$SECRET_KEY_BASE
SESSION_SECRET=$SESSION_SECRET
VERIFICATION_SECRET=$VERIFICATION_SECRET

# External services (sandbox / scoped review-app values).
# Stripe is intentionally absent — review apps read it from the committed .env
# (dotenv in staging); see config/environments/staging.rb + Gemfile.
GOOGLE_MAPS=$GOOGLE_MAPS
GOOGLE_MAPS_STATIC=$GOOGLE_MAPS_STATIC
GOOGLE_GEOCODER=$GOOGLE_GEOCODER
MAPBOX_GEOCODER=$MAPBOX_GEOCODER
MAPBOX_MAPPING=$MAPBOX_MAPPING
R2_DEV_ENDPOINT=$R2_DEV_ENDPOINT
R2_DEV_ACCESS_KEY=$R2_DEV_ACCESS_KEY
R2_DEV_ACCESS_KEY_SECRET=$R2_DEV_ACCESS_KEY_SECRET
HONEYBADGER_API_KEY=$HONEYBADGER_API_KEY
HONEYBADGER_FRONTEND_API_KEY=$HONEYBADGER_FRONTEND_API_KEY
