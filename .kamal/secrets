# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.review.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.
#
# For local deploys, secrets come from 1Password and the gh CLI (see below).
# For CI deploys, the workflow copies .kamal/secrets-ci over this file before
# invoking kamal — so CI deploys read the GitHub Actions env-var passthrough
# instead. See docs/review-apps.md.

KAMAL_REGISTRY_PASSWORD=$(gh auth token)

SECRETS=$(kamal secrets fetch --adapter 1password --account bike-index --from "Kamal/BikeIndex Review" POSTGRES_PASSWORD SECRET_KEY_BASE SESSION_SECRET VERIFICATION_SECRET STRIPE_PUBLISHABLE_KEY STRIPE_SECRET_KEY STRIPE_WEBHOOK_SECRET GOOGLE_MAPS GOOGLE_MAPS_STATIC GOOGLE_GEOCODER MAPBOX_GEOCODER MAPBOX_MAPPING R2_DEV_ENDPOINT R2_DEV_ACCESS_KEY R2_DEV_ACCESS_KEY_SECRET HONEYBADGER_API_KEY)

# Postgres: one password reused for the admin role and every per-PR role
# (see bin/docker-entrypoint).
POSTGRES_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD ${SECRETS})
POSTGRESQL_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD ${SECRETS})
ANALYTICS_DB_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD ${SECRETS})

# App secrets
SECRET_KEY_BASE=$(kamal secrets extract SECRET_KEY_BASE ${SECRETS})
SESSION_SECRET=$(kamal secrets extract SESSION_SECRET ${SECRETS})
VERIFICATION_SECRET=$(kamal secrets extract VERIFICATION_SECRET ${SECRETS})

# External services (sandbox / scoped review-app values — do NOT reuse prod)
STRIPE_PUBLISHABLE_KEY=$(kamal secrets extract STRIPE_PUBLISHABLE_KEY ${SECRETS})
STRIPE_SECRET_KEY=$(kamal secrets extract STRIPE_SECRET_KEY ${SECRETS})
STRIPE_WEBHOOK_SECRET=$(kamal secrets extract STRIPE_WEBHOOK_SECRET ${SECRETS})
GOOGLE_MAPS=$(kamal secrets extract GOOGLE_MAPS ${SECRETS})
GOOGLE_MAPS_STATIC=$(kamal secrets extract GOOGLE_MAPS_STATIC ${SECRETS})
GOOGLE_GEOCODER=$(kamal secrets extract GOOGLE_GEOCODER ${SECRETS})
MAPBOX_GEOCODER=$(kamal secrets extract MAPBOX_GEOCODER ${SECRETS})
MAPBOX_MAPPING=$(kamal secrets extract MAPBOX_MAPPING ${SECRETS})
R2_DEV_ENDPOINT=$(kamal secrets extract R2_DEV_ENDPOINT ${SECRETS})
R2_DEV_ACCESS_KEY=$(kamal secrets extract R2_DEV_ACCESS_KEY ${SECRETS})
R2_DEV_ACCESS_KEY_SECRET=$(kamal secrets extract R2_DEV_ACCESS_KEY_SECRET ${SECRETS})
HONEYBADGER_API_KEY=$(kamal secrets extract HONEYBADGER_API_KEY ${SECRETS})
