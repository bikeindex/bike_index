#!/bin/sh

# Notify Honeybadger of the deploy by running the `trigger_honeybadger_deploy`
# rake task INSIDE the freshly-deployed container, via `kamal app exec`. The
# container is the only place with all three of: the gem bundle, a bootable Rails
# runtime (DB/Redis configured), and the HONEYBADGER_* keys — the CI runner and
# the local host each lack one. So kamal on the runner needs no bundle; it just
# `docker exec`s the task. (`kamal app exec` takes no deploy lock, so this is safe
# from a post-deploy hook.)
#
# The container has no .git, so the revision is computed here (the runner/local
# host does have the checkout) and passed in as DEPLOY_SHA. Best-effort: this must
# NEVER fail the deploy.
revision="$(git rev-parse HEAD 2>/dev/null || echo "$KAMAL_VERSION")"

kamal app exec --reuse --config-file config/deploy.review.yml \
  "DEPLOY_SHA=$revision bin/rails trigger_honeybadger_deploy" \
  || echo "Honeybadger deploy notification skipped/failed (non-fatal)"
exit 0
