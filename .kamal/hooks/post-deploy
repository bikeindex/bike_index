#!/bin/sh

# Best-effort Honeybadger deploy notification via the `trigger_honeybadger_deploy`
# rake task (notifies the Rails backend + frontend [+ CSP] projects). This must
# NEVER fail the deploy.
#
# NOTE: the task loads the Rails env (`:environment`) and reads `git rev-parse
# HEAD`, so it needs both the app bundle AND a git checkout. On a LOCAL deploy
# both are present and it runs. On the CI runner the app bundle isn't installed
# (the workflow installs only kamal), so `bundle exec rake` is "command not
# found" and the `|| echo` below makes it a non-fatal no-op. To notify on CI
# deploys, the workflow would need to `bundle install` first.
[ -z "$HONEYBADGER_API_KEY" ] && exit 0

bundle exec rake trigger_honeybadger_deploy \
  || echo "Honeybadger deploy notification skipped/failed (non-fatal)"
exit 0
